{% extends 'base.html.twig' %}

{% block title %}Desserts & Prix — SamyDessert{% endblock %}

{% block body %}

{# ── Hero ── #}
<section class="section-alt">
  <div class="container-main">
    <h1 class="text-h1 font-bold text-text mb-2">Nos desserts</h1>
    <p class="text-text-light text-body">Pâtisseries artisanales préparées chaque jour avec des ingrédients frais.</p>
  </div>
</section>

{# ── Barre de recherche ── #}
<twig:Molecules:SearchBar
  action="{{ path('app_produits') }}"
  value="{{ recherche }}"
  placeholder="Rechercher un dessert..."
  frameId="produits-results"
>
  <twig:block name="extra_inputs">
    {% if categorieActive %}
      <input type="hidden" name="categorie" value="{{ categorieActive }}">
    {% endif %}
  </twig:block>
</twig:Molecules:SearchBar>

{# ── Contenu principal : sidebar + grille ── #}
<turbo-frame id="produits-results">
<section class="section">
  <div class="container-main">
    <div class="flex flex-col lg:flex-row gap-10">

      {# ── Sidebar catégories ── #}
      <aside class="lg:w-56 shrink-0">
        <h2 class="text-small font-semibold uppercase tracking-wider text-text-light mb-4">Catégories</h2>
        <ul class="flex flex-row flex-wrap gap-2 lg:flex-col lg:gap-1">

          <li>
            {% set hrefTous = recherche ? path('app_produits') ~ '?q=' ~ recherche|url_encode : path('app_produits') %}
            <twig:Atoms:Link
              href="{{ hrefTous }}"
              data-turbo-frame="produits-results"
              class="block w-full rounded-lg px-4 py-2 font-medium transition text-left text-small {{ categorieActive == '' ? 'bg-accent text-white' : 'text-text hover:bg-surface' }}"
            >
              Tous les desserts
            </twig:Atoms:Link>
          </li>

          {% for slug, label in categories %}
            <li>
              {% set hrefCat = recherche ? path('app_produits') ~ '?categorie=' ~ slug ~ '&q=' ~ recherche|url_encode : path('app_produits') ~ '?categorie=' ~ slug %}
              <twig:Atoms:Link
                href="{{ hrefCat }}"
                data-turbo-frame="produits-results"
                class="block w-full rounded-lg px-4 py-2 font-medium transition text-left text-small {{ categorieActive == slug ? 'bg-accent text-white' : 'text-text hover:bg-surface' }}"
              >
                {{ label }}
              </twig:Atoms:Link>
            </li>
          {% endfor %}

        </ul>
      </aside>

      {# ── Grille de produits ── #}
      <div class="flex-1">

        <form method="get" action="{{ path('app_produits') }}" class="flex items-center justify-end mb-6">
          {% if recherche %}<input type="hidden" name="q" value="{{ recherche }}">{% endif %}
          {% if categorieActive %}<input type="hidden" name="categorie" value="{{ categorieActive }}">{% endif %}
          <label for="tri" class="text-small text-text-light mr-2 shrink-0">Trier par</label>
          <select
            id="tri"
            name="tri"
            onchange="this.form.submit()"
            class="rounded-md border border-border bg-bg px-3 py-1.5 text-small text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            <option value="" {{ tri == '' ? 'selected' : '' }}>Par défaut</option>
            <option value="prix_asc" {{ tri == 'prix_asc' ? 'selected' : '' }}>Prix croissant</option>
            <option value="prix_desc" {{ tri == 'prix_desc' ? 'selected' : '' }}>Prix décroissant</option>
            <option value="note" {{ tri == 'note' ? 'selected' : '' }}>Mieux notés</option>
          </select>
        </form>

        <p class="text-small text-text-light mb-6">
          {% if recherche %}
            {{ produits|length }} résultat{% if produits|length > 1 %}s{% endif %} pour « {{ recherche }} »
          {% else %}
            {{ produits|length }} dessert{% if produits|length > 1 %}s{% endif %}
            {% if categorieActive %} dans « {{ categories[categorieActive] }} »{% endif %}
          {% endif %}
        </p>

        {% if produits is empty %}
          <div class="text-center py-16 text-text-light">
            <twig:Atoms:Icon name="face-sad-tear" :decorative="true" class="text-h2 mb-4 block"/>
            <p class="text-body font-medium">Aucun dessert trouvé.</p>
            <twig:Atoms:Link href="{{ path('app_produits') }}" class="mt-4 inline-block text-small text-accent">
              Voir tous les desserts
            </twig:Atoms:Link>
          </div>
        {% else %}
          <twig:Organisms:ProductCardGrid :items="produits" :favorisIds="produitsFavorisIds" :ratingsMap="notesMap" />
        {% endif %}

      </div>
    </div>
  </div>
</section>
</turbo-frame>

{# ── CTA commande ── #}
<section class="py-16 bg-accent">
  <div class="container-main text-center">
    <h2 class="text-h4 font-bold text-white mb-3">Vous ne trouvez pas ce que vous cherchez ?</h2>
    <p class="text-surface mb-6">Contactez-nous pour une commande sur mesure.</p>
    <twig:Atoms:Link
      href="{{ path('app_contact') }}"
      class="inline-flex items-center gap-2 bg-bg text-text-light px-8 py-3 rounded-full font-semibold hover:bg-surface transition"
    >
      Nous contacter
      <twig:Atoms:Icon name="envelope" :decorative="true"/>
    </twig:Atoms:Link>
  </div>
</section>

{% endblock %}
