{% extends 'base.html.twig' %}

{% block title %}Recettes — SamyDessert{% endblock %}

{% block body %}

{# ── Hero ── #}
<section class="section-alt">
  <div class="container-main">
    <h1 class="text-h1 font-bold text-text mb-2">Nos recettes</h1>
    <p class="text-text-light text-body">Retrouvez toutes nos recettes de pâtisserie, des plus simples aux plus élaborées.</p>
  </div>
</section>

{# ── Barre de recherche ── #}
<twig:Molecules:SearchBar
  action="{{ path('app_recettes') }}"
  value="{{ recherche }}"
  placeholder="Rechercher une recette..."
  frameId="recettes-results"
>
  <twig:block name="extra_inputs">
    {% if categorieActive %}
      <input type="hidden" name="categorie" value="{{ categorieActive }}">
    {% endif %}
  </twig:block>
</twig:Molecules:SearchBar>

{# ── Contenu principal : sidebar + grille ── #}
<turbo-frame id="recettes-results">
<section class="section">
  <div class="container-main">
    <div class="flex flex-col lg:flex-row gap-10">

      {# ── Sidebar catégories ── #}
      <aside class="lg:w-56 shrink-0">
        <h2 class="text-small font-semibold uppercase tracking-wider text-text-light mb-4">Catégories</h2>
        <ul class="flex flex-row flex-wrap gap-2 lg:flex-col lg:gap-1">

          <li>
            {% set hrefTous = recherche ? path('app_recettes') ~ '?q=' ~ recherche|url_encode : path('app_recettes') %}
            <twig:Atoms:Link
              href="{{ hrefTous }}"
              data-turbo-frame="recettes-results"
              class="block w-full rounded-lg px-4 py-2 font-medium transition text-left text-small {{ categorieActive == '' ? 'bg-accent text-white' : 'text-text hover:bg-surface' }}"
            >
              Toutes les recettes
            </twig:Atoms:Link>
          </li>

          {% for slug, label in categories %}
            <li>
              {% set hrefCat = recherche ? path('app_recettes') ~ '?categorie=' ~ slug ~ '&q=' ~ recherche|url_encode : path('app_recettes') ~ '?categorie=' ~ slug %}
              <twig:Atoms:Link
                href="{{ hrefCat }}"
                data-turbo-frame="recettes-results"
                class="block w-full rounded-lg px-4 py-2 font-medium transition text-left text-small {{ categorieActive == slug ? 'bg-accent text-white' : 'text-text hover:bg-surface' }}"
              >
                {{ label }}
              </twig:Atoms:Link>
            </li>
          {% endfor %}

        </ul>
      </aside>

      {# ── Grille de recettes ── #}
      <div class="flex-1">

        <form method="get" action="{{ path('app_recettes') }}" class="flex items-center justify-end mb-6">
          {% if recherche %}<input type="hidden" name="q" value="{{ recherche }}">{% endif %}
          {% if categorieActive %}<input type="hidden" name="categorie" value="{{ categorieActive }}">{% endif %}
          <label for="tri" class="text-small text-text-light mr-2 shrink-0">Trier par</label>
          <select
            id="tri"
            name="tri"
            onchange="this.form.submit()"
            class="rounded-md border border-border bg-bg px-3 py-1.5 text-small text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            <option value="" {{ tri == '' ? 'selected' : '' }}>Plus récentes</option>
            <option value="difficulte_asc" {{ tri == 'difficulte_asc' ? 'selected' : '' }}>Facile → Difficile</option>
            <option value="difficulte_desc" {{ tri == 'difficulte_desc' ? 'selected' : '' }}>Difficile → Facile</option>
          </select>
        </form>

        <p class="text-small text-text-light mb-6">
          {% if recherche %}
            {{ recettes|length }} résultat{% if recettes|length > 1 %}s{% endif %} pour « {{ recherche }} »
          {% else %}
            {{ recettes|length }} recette{% if recettes|length > 1 %}s{% endif %}
            {% if categorieActive %} dans « {{ categories[categorieActive] }} »{% endif %}
          {% endif %}
        </p>

        <twig:Organisms:ProductCardGrid
          :items="recettes"
          type="recette"
          :favorisIds="recettesFavorisIds"
        />

      </div>
    </div>
  </div>
</section>
</turbo-frame>

{# ── CTA ── #}
<section class="py-16 bg-accent">
  <div class="container-main text-center">
    <h2 class="text-h4 font-bold text-white mb-3">Envie de déguster sans cuisiner ?</h2>
    <p class="text-surface mb-6">Commandez nos créations fraîches, préparées chaque jour par nos artisans.</p>
    <twig:Atoms:Link
      href="{{ path('app_produits') }}"
      class="inline-flex items-center gap-2 bg-bg text-accent px-8 py-3 rounded-full font-semibold hover:bg-surface transition"
    >
      Voir nos desserts
      <twig:Atoms:Icon name="cake-candles" :decorative="true"/>
    </twig:Atoms:Link>
  </div>
</section>

{% endblock %}
