{% set titleId = this.titleId %}
{% set tag = this.safeTitleTag %}

<article
  {% if id is not empty %}id="{{ id }}"{% endif %}
  {% if title is not empty %}aria-labelledby="{{ titleId }}"{% endif %}
  {{ attributes.defaults({
    class: "card"
  }) }}
>
  {% if title is not empty %}
    <{{ tag }} id="{{ titleId }}" class="px-4 pt-4 text-body font-bold text-text">
      {{ title }}
    </{{ tag }}>
  {% endif %}

  <div class="p-4 {% if title is not empty %}pt-2{% endif %}">
    {% block content %}{% endblock %}
  </div>
</article>

{#
  Props (* = obligatoire) :
  - id          string      — identifiant HTML ('')
  - title       string|null — titre affiché en en-tête (null)
  - titleTag    string      — balise du titre : h2 | h3 | h4 | h5 (h3)

  Utilisation :
  <twig:Atoms:Card>Contenu simple</twig:Atoms:Card>
  <twig:Atoms:Card title="Mes commandes">...</twig:Atoms:Card>
  <twig:Atoms:Card id="profil" title="Mon profil" titleTag="h2">...</twig:Atoms:Card>
#}
