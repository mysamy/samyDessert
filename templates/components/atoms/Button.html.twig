{% set base =
  "inline-flex items-center gap-2 rounded-md font-normal transition
   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2
   disabled:opacity-50 disabled:pointer-events-none"
%}

{% set sizes = {
  sm: "h-9 px-3 text-small",
  md: "h-10 px-4 text-body",
  lg: "h-11 px-6 text-body"
} %}

{% set variants = {
  primary: "bg-accent text-white hover:bg-primary focus-visible:ring-accent",
  secondary: "bg-surface text-text hover:bg-border focus-visible:ring-border",
  ghost: "bg-transparent text-text hover:bg-surface focus-visible:ring-border"
} %}

<button
  type="{{ type }}"
  {% if disabled %}disabled{% endif %}
  {{ attributes.defaults({
    class: base ~ ' ' ~ (sizes[size] ?? sizes.md) ~ ' ' ~ (variants[variant] ?? variants.primary)
  }) }}
>
   {% block content %}{% endblock %}
</button>

{#
  Props (* = obligatoire) :
  - type        string  — type du bouton : button | submit | reset (button)
  - variant     string  — style visuel : primary | secondary | ghost (primary)
  - size        string  — taille : sm | md | lg (md)
  - disabled    bool    — désactivé (false)

  Utilisation :
  <twig:Atoms:Button>Commander</twig:Atoms:Button>
  <twig:Atoms:Button variant="secondary" size="sm">Annuler</twig:Atoms:Button>
  <twig:Atoms:Button variant="ghost" size="lg">En savoir plus</twig:Atoms:Button>
  <twig:Atoms:Button type="submit" :disabled="true">Valider</twig:Atoms:Button>
#}
