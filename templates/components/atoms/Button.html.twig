{% set base =
  "inline-flex items-center gap-2 rounded-md font-medium transition
   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2
   disabled:opacity-50 disabled:pointer-events-none"
%}

{% set sizes = {
  sm: "h-9 px-3 text-sm",
  md: "h-10 px-4 text-sm",
  lg: "h-11 px-6 text-base"
} %}

{% set variants = {
  primary: "bg-black text-white hover:opacity-90 focus-visible:ring-black",
  secondary: "bg-gray-200 text-black hover:bg-gray-300 focus-visible:ring-gray-400",
  ghost: "bg-transparent text-black hover:bg-gray-100 focus-visible:ring-gray-400"
} %}

<button
  type="{{ type }}"
  {% if disabled %}disabled{% endif %}
  {{ attributes.defaults({
    class: base ~ ' ' ~ (sizes[size] ?? sizes.md) ~ ' ' ~ (variants[variant] ?? variants.primary)
  }) }}
>
   {{ content|default('') }}
</button>
