{% set href = this.href %}
{% set external = this.external %}
{% set ariaLabel = this.ariaLabel %}

<a
  href="{{ href }}"
  {% if external %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}
  {% if ariaLabel %}
    aria-label="{{ ariaLabel }}"
  {% endif %}
  {{ attributes.defaults({ class: 'inline-flex items-center' }) }}
>
  {% block content %}{% endblock %}
</a>