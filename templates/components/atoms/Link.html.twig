<a
  {% if external %}target="_blank" rel="noopener noreferrer"{% endif %}
  {% if current %}aria-current="page"{% endif %}
  {{ attributes.defaults({ class: 'nav-link inline-flex items-center transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm' }) }}
>
  {% block content %}{% endblock %}
</a>

{#
  Props (* = obligatoire) :
  - external  bool — ajoute target="_blank" rel="noopener noreferrer" (false)
  - current   bool — ajoute aria-current="page" pour la nav (false)

  Attributs HTML utiles (via attributes) :
  - href*       — URL de destination
  - aria-label  — si le texte du lien n'est pas explicite

  Utilisation :
  <twig:Atoms:Link href="{{ path('app_home') }}">Accueil</twig:Atoms:Link>
  <twig:Atoms:Link href="https://stripe.com" :external="true">Payer</twig:Atoms:Link>
  <twig:Atoms:Link href="{{ path('app_produits') }}" :current="true">Produits</twig:Atoms:Link>
#}
