{% set sizes = {
  sm: "h-4 w-4",
  md: "h-6 w-6",
  lg: "h-8 w-8"
} %}

<svg
  class="animate-spin text-gray-600 {{ sizes[size] ?? sizes.md }}"
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  role="status"
  aria-label="{{ ariaLabel }}"
>
  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
  <path class="opacity-75" fill="currentColor"
        d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
</svg>

{#
  Props (* = obligatoire) :
  - size        string  — taille : sm | md | lg (md)
  - ariaLabel   string  — texte accessible pour le lecteur d'écran ('Chargement')

  Utilisation :
  <twig:Atoms:Spinner />
  <twig:Atoms:Spinner size="sm" />
  <twig:Atoms:Spinner size="lg" ariaLabel="Chargement du panier" />
#}
