{% set base =
  "block w-full rounded-md border border-border bg-surface px-3 py-2 text-small text-text
   focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent
   disabled:bg-border disabled:cursor-not-allowed"
%}

<input
  type="{{ type }}"
  {% if value is not null %}value="{{ value }}"{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if required %}required{% endif %}
  {{ ((attributes.get('pattern') ?? '') != '' ? attributes : attributes.without('pattern')).defaults({
    class: base
  }) }}
/>

{#
  Props (* = obligatoire via attributes, pas de prop PHP requise) :
  - name*       string      — identifiant du champ (via attributes)
  - type        string      — type HTML du champ (text)
  - value       string|null — valeur pré-remplie (null)
  - disabled    bool        — désactivé (false)
  - required    bool        — obligatoire (false)

  Utilisation :
  <twig:Atoms:Input name="email" type="email" placeholder="votre@email.com" />
  <twig:Atoms:Input name="prix" type="number" :required="true" value="9.90" />
  <twig:Atoms:Input name="code" :disabled="true" value="CMD-2026-00001" />
#}
