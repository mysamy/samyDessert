<label {{ attributes.defaults({ class: 'text-small font-bold text-text' }) }}>
  {{ label }}
  {% if required %}<span class="text-danger ml-0.5" aria-hidden="true">*</span>{% endif %}
  {% if optional %}<span class="text-text-light font-normal text-small ml-1">(optionnel)</span>{% endif %}
</label>

{#
  Props (* = obligatoire) :
  - label*   string — texte du label
  - required bool   — affiche un * rouge (false)

  Attributs HTML utiles (via attributes) :
  - for — id du champ associé

  Utilisation :
  <twig:Atoms:Label for="email" label="Adresse email" :required="true" />
  <twig:Atoms:Label for="password" label="Mot de passe" class="mb-1 block" />
#}
