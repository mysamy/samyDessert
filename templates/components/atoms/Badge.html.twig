{% set variants = {
    default: "bg-surface text-text",
    warning: "bg-surface text-accent",
    success: "bg-success-light text-success",
    danger:  "bg-danger-light text-danger"
} %}

<span {{ attributes.defaults({
    class: "inline-block rounded-full px-3 pt-1.5 pb-0.5 text-small font-normal " ~ (variants[this.variant] ?? variants.default)
}) }}>
    {% block content %}{% endblock %}
</span>

{#
  Props (* = obligatoire) :
  - variant     string  — style visuel : default | warning | success | danger (default)

  Utilisation :
  <twig:Atoms:Badge>Nouveau</twig:Atoms:Badge>
  <twig:Atoms:Badge variant="success">Confirmée</twig:Atoms:Badge>
  <twig:Atoms:Badge variant="danger">Annulée</twig:Atoms:Badge>
  <twig:Atoms:Badge variant="warning">En attente</twig:Atoms:Badge>
#}
