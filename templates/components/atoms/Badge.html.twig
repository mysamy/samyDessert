{% set variants = {
    default: "bg-surface text-text",
    primary: "bg-primary text-white",
    warning: "bg-surface text-accent",
    success: "bg-success-light text-success",
    danger:  "bg-danger-light text-danger"
} %}

<span {{ attributes.defaults({
    class: "inline-flex items-center rounded-full px-3 py-1 text-small font-medium " ~ (variants[this.variant] ?? variants.default)
}) }}>
    {% block content %}{% endblock %}
</span>