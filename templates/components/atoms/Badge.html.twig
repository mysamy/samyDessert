<span {{ attributes.defaults({
    class: "inline-block rounded-full px-3 pt-1.5 pb-0.5 text-small font-normal " ~ (
        variant == 'warning' ? 'bg-warning-light text-warning' :
        variant == 'success' ? 'bg-success-light text-success' :
        variant == 'danger'  ? 'bg-danger-light text-danger'  :
        'bg-surface text-text'
    )
}) }}>
    {% block content %}{% endblock %}
</span>

{#
  Props (* = obligatoire) :
  - variant     string  — style visuel : default | warning | success | danger (default)
                          warning = bg-warning-light text-warning (amber)

  Utilisation :
  twig:Atoms:Badge — Nouveau
  twig:Atoms:Badge variant="success" — Confirmée
  twig:Atoms:Badge variant="danger" — Annulée
  twig:Atoms:Badge variant="warning" — En attente
#}
