<footer {{ attributes.defaults({ class: 'divider bg-surface' }) }}>
  <div class="mx-auto max-w-7xl px-4 py-12">

    {# Haut : marque + réseaux #}
    <div class="flex flex-col items-center gap-6 mb-8">
      <div class="text-center">
        {% if logoSrc %}
          <img src="{{ logoSrc }}" alt="{{ logoAlt ?: brandLabel }}" class="h-16 w-auto mx-auto">
        {% elseif brandLabel %}
          <div class="text-small font-semibold text-text">{{ brandLabel }}</div>
        {% endif %}
        {% if tagline %}
          <p class="mt-1 text-small text-text-light">{{ tagline }}</p>
        {% endif %}
      </div>

      {% if socialLinks %}
        <div class="flex items-center gap-5">
          {% for social in socialLinks %}
            <twig:Atoms:Link
              href="{{ social.href }}"
              :external="true"
              class="inline-block transition duration-350 hover:rotate-12 hover:scale-110 text-text-light hover:text-accent"
              aria-label="{{ social.label }}"
            >
              <twig:Atoms:Icon name="{{ social.icon }}" variant="{{ social.variant|default('brands') }}" size="xl" :decorative="true" />
            </twig:Atoms:Link>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# Milieu : liens de navigation #}
    {% if links %}
      <twig:Molecules:Nav
        ariaLabel="Navigation pied de page"
        :links="links"
        class="flex-wrap justify-center text-small gap-4"
      />
    {% endif %}

    {# Bas : copyright + liens légaux #}
    <div class="mt-8 border-t border-border pt-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      {% if legalText %}
        <span class="text-small text-text-light">{{ legalText }}</span>
      {% endif %}

      {% if legalLinks %}
        <div class="flex items-center gap-4">
          {% for link in legalLinks %}
            <twig:Atoms:Link href="{{ link.href }}" class="text-small text-text-light hover:text-accent hover:underline transition">
              {{ link.label }}
            </twig:Atoms:Link>
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>
</footer>

{#
  Props :
  - brandLabel  string      — nom de la marque ('')
  - tagline     string      — phrase d'accroche sous le nom ('')
  - links       array       — liens nav { label, href } ([])
  - legalLinks  array       — liens légaux { label, href } ([])
  - socialLinks array       — { label, href, icon, variant? } ([])
  - legalText   string|null — texte copyright (null)
#}
