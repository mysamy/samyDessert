{% set hasTitle = title is not empty %}
{% set normalizedItems = this.normalizedItems %}
{% set hasItems = normalizedItems|length > 0 %}

{% set attrDefaults = {} %}
{% if id %}{% set attrDefaults = attrDefaults|merge({ id: id }) %}{% endif %}
{% if hasTitle %}{% set attrDefaults = attrDefaults|merge({ 'aria-labelledby': this.titleId }) %}{% endif %}

{% set rootAttrs = attributes.defaults(attrDefaults) %}
{% set rootAttrs = class ? rootAttrs.addClass(class) : rootAttrs %}

<section {{ rootAttrs }}>
  {% if hasTitle %}
    <h2 id="{{ this.titleId }}" class="text-body font-semibold text-text">
      {{ title }}
    </h2>
  {% endif %}

  {% if hasItems %}
    <ul role="list" class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
      {% for item in normalizedItems %}
        <li>
          <twig:Organisms:DessertCard
            :titre="item.titre"
            :url="item.url"
            :imageSrc="item.imageSrc"
            :rating="item.rating"
            :prix="item.prix"
            :description="item.description"
            :difficulte="item.difficulte"
            :temps="item.temps"
            :portions="item.portions"
            :categorieLabel="item.categorieLabel"
            :produitId="item.produitId"
            :favori="item.favori"
            :favoriUrl="item.favoriUrl"
          />
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="rounded-lg border border-border bg-surface p-6 text-text">
      <p>Aucun {{ type == 'recette' ? 'recette' : 'produit' }} à afficher.</p>
    </div>
  {% endif %}
</section>

{#
  Props (* = obligatoire) :
  - items*      array       — produits ou recettes (entités Symfony)
  - type        string      — 'produit' (défaut) ou 'recette'
  - title       string|null — titre de la section (null)
  - id          string|null — identifiant HTML de la section (null)
  - favorisIds  array       — IDs des favoris de l'utilisateur ([])
  - ratingsMap  array       — map id => noteMoyenne ([])

  Utilisation :
  <twig:Organisms:ProductCardGrid :items="produits" title="Nos produits" />
  <twig:Organisms:ProductCardGrid :items="recettes" type="recette" title="Nos recettes" />
#}
