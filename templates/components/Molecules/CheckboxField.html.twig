<div {{ attributes.defaults({ class: 'flex items-start gap-2' }) }}>
  <twig:Atoms:Checkbox
    id="{{ id }}"
    name="{{ name }}"
    :checked="checked"
    :required="required"
    :disabled="disabled"
    aria-invalid="{{ error ? 'true' : 'false' }}"
    aria-describedby="{{ error ? this.errorId : '' }}"
    class="mt-0.5"
  />

  <div>
    <twig:Atoms:Label for="{{ id }}" label="{{ label }}" />

    {% if error %}
      <p id="{{ this.errorId }}" class="mt-0.5 text-small text-danger" role="alert">
        {{ error }}
      </p>
    {% endif %}
  </div>
</div>

{#
  Props (* = obligatoire) :
  - id*         string      — identifiant HTML du champ
  - label*      string      — texte du label
  - checked     bool        — coché par défaut (false)
  - required    bool        — obligatoire (false)
  - disabled    bool        — désactivé (false)
  - error       string|null — message d'erreur (null)

  Utilisation :
  <twig:Molecules:CheckboxField id="cgv" label="J'accepte les conditions générales" :required="true" />
  <twig:Molecules:CheckboxField id="newsletter" label="Recevoir les offres" :checked="true" />
  <twig:Molecules:CheckboxField id="cgv" label="CGV" error="{{ errors.cgv }}" />
#}
