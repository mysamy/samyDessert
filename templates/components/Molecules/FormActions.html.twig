{% set alignmentClass = this.alignmentClass %}

<div
  {{ attributes.defaults({ class: 'mt-6 flex items-center gap-3 ' ~ alignmentClass }) }}
  {% if disabled %}aria-disabled="true"{% endif %}
>
  {% block content %}{% endblock %}
</div>

{#
  Props (* = obligatoire) :
  - align       string  — alignement : start | center | end | between (end)
  - disabled    bool    — désactive le groupe d'actions (false)

  Utilisation :
  <twig:Molecules:FormActions>
    <twig:Atoms:Button type="submit">Enregistrer</twig:Atoms:Button>
  </twig:Molecules:FormActions>

  <twig:Molecules:FormActions align="between">
    <twig:Atoms:Button variant="ghost">Annuler</twig:Atoms:Button>
    <twig:Atoms:Button type="submit">Envoyer</twig:Atoms:Button>
  </twig:Molecules:FormActions>
#}
