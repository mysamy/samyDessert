{% set id = this.computedId %}
{% set describedBy = this.ariaDescribedBy %}
{% set hasLegend = this.hasLegend %}
{% set legendId = this.legendId %}
{% set descriptionId = this.descriptionId %}
{% set tag = hasLegend ? 'fieldset' : 'div' %}

<{{ tag }}
  id="{{ id }}"
  {% if not hasLegend %}role="group"{% endif %}
  {% if describedBy %}aria-describedby="{{ describedBy }}"{% endif %}
  {{ attributes.defaults({ class: '' }) }}
>
  {% if hasLegend %}
    <legend id="{{ legendId }}" class="text-small font-semibold text-text">
      {{ legend }}
    </legend>
  {% endif %}

  {% if description %}
    <p id="{{ descriptionId }}" class="{% if hasLegend %}mt-1{% endif %} text-small text-text-light">{{ description }}</p>
  {% endif %}

  <div class="{% if description or hasLegend %}mt-4{% endif %} {{ innerClass }}">
    {% block content %}{% endblock %}
  </div>
</{{ tag }}>

{#
  Props (* = obligatoire) :
  - legend      string      — titre du groupe, génère un <fieldset> si renseigné ('')
  - description string|null — description affichée sous le legend (null)
  - id          string      — identifiant du groupe ('')
  - innerClass  string      — classes CSS sur le conteneur interne ('space-y-4')

  Utilisation :
  <twig:Molecules:FormFieldGroup legend="Informations personnelles">
    <twig:Molecules:InputField name="prenom" label="Prénom" />
    <twig:Molecules:InputField name="nom" label="Nom" />
  </twig:Molecules:FormFieldGroup>
#}
