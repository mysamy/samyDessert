<section {{ attributes.defaults({ class: 'bg-bg border-b border-border py-6' }) }}>
  <div class="container-main">
    <form method="GET" action="{{ action }}" class="flex gap-3 max-w-xl" {% if frameId %}data-turbo-frame="{{ frameId }}"{% endif %}>
      <twig:Atoms:Input
        type="search"
        name="{{ name }}"
        value="{{ value }}"
        placeholder="{{ placeholder }}"
        aria-label="{{ placeholder }}"
        class="flex-1 rounded-full px-5 py-2.5"
      />
      {% block extra_inputs %}{% endblock %}
      <twig:Atoms:Button type="submit" class="rounded-full px-5 py-2.5">
        <twig:Atoms:Icon name="magnifying-glass" :decorative="true"/>
        {{ buttonLabel }}
      </twig:Atoms:Button>
    </form>
  </div>
</section>

{#
  Props (* = obligatoire) :
  - action*     string  — URL de soumission du formulaire
  - value       string  — valeur pré-remplie du champ ('')
  - name        string  — name du champ de recherche (q)
  - placeholder string  — placeholder du champ ('Rechercher...')
  - buttonLabel string  — libellé du bouton ('Rechercher')

  Utilisation :
  <twig:Molecules:SearchBar action="{{ path('app_produits') }}" value="{{ app.request.query.get('q') }}" />
  <twig:Molecules:SearchBar action="{{ path('app_recettes') }}" placeholder="Chercher une recette..." />
#}
