<nav {{ attributes.defaults({ class: 'flex' }) }} aria-label="{{ ariaLabel }}">
  <ul class="flex items-center gap-6">
    {% for item in links %}
      {% set label = item.label|default('') %}
      {% set href = item.href|default('') %}
      {% set isCurrent = item.current|default(false) %}

      {% if label is not empty and href is not empty %}
        <li>
          <twig:Atoms:Link href="{{ href }}" :current="isCurrent" class="nav__link text-text hover:text-accent">
            {{ label }}
          </twig:Atoms:Link>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</nav>

{#
  Props (* = obligatoire) :
  - links*      array   — tableau de liens { label, href, current? }
  - ariaLabel   string  — aria-label de la balise <nav> ('Navigation principale')

  Utilisation :
  <twig:Molecules:Nav :links="[
    { label: 'Accueil', href: path('app_home') },
    { label: 'Produits', href: path('app_produits'), current: true },
    { label: 'Recettes', href: path('app_recettes') },
  ]" />
#}
