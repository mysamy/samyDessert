<div {{ attributes.defaults({ class: 'flex flex-col p-5 h-[400px] w-[700px] max-[1500px]:w-[500px] max-[1500px]:h-[450px] max-[1100px]:w-[120%] max-[1100px]:p-[10px] max-[425px]:h-[400px] max-[425px]:w-[140%] rounded-2xl relative overflow-hidden' }) }}>

{% block content %}
        {% if imgSrc %}
            <div class="relative flex-1 min-h-0 w-full rounded-[10px] overflow-hidden {{ imgClass }}">
                <twig:Atoms:Image src="{{ imgSrc }}" alt="{{ imgAlt }}" class="absolute inset-0 w-full h-full object-cover" />
            </div>
        {% endif %}
        {% if description %}
            <p class="text-text text-center text-sm mt-2 shrink-0">{{ description }}</p>
        {% endif %}
    {% endblock %}

</div>

{#
  Props (* = obligatoire) :
  - imgSrc      string  — URL de l'image ('')
  - imgAlt      string  — texte alternatif de l'image ('')
  - imgClass    string  — classes CSS supplémentaires sur le conteneur image ('')
  - description string  — texte descriptif de l'étape ('')

  Utilisation :
  <twig:Molecules:CarouselCard :number="1" imgSrc="/images/etape1.jpg" imgAlt="Étape 1" description="Préparez la pâte." />
  <twig:Molecules:CarouselCard :number="2" description="Laissez reposer 30 minutes." />
#}
