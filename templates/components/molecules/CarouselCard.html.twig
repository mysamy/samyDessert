<div {{ attributes.defaults({ class: 'flex flex-col w-full h-4/5 rounded-lg' }) }}>

{% block content %}
        {% if url %}
            <a href="{{ url }}" class="flex-1 min-h-0 w-full flex flex-col gap-2.5">
        {% endif %}
        {% if imgSrc %}
            <div class="flex-1 min-h-0 w-full {{ imgClass }}">
                <twig:Atoms:Image src="{{ imgSrc }}" alt="{{ imgAlt }}" loading="eager" class="w-full h-full object-contain" />
            </div>
        {% endif %}
        {% if description %}
            <p class="carousel-card-description text-primary text-center text-small shrink-0 opacity-0 relative z-10 line-clamp-2 h-12">{{ description }}</p>
        {% endif %}
        {% if url %}
            </a>
        {% endif %}
    {% endblock %}

</div>

{#
  Props (* = obligatoire) :
  - imgSrc      string  — URL de l'image ('')
  - imgAlt      string  — texte alternatif de l'image ('')
  - imgClass    string  — classes CSS supplémentaires sur le conteneur image ('')
  - description string  — texte descriptif de l'étape ('')

  Utilisation :
  <twig:Molecules:CarouselCard :number="1" imgSrc="/images/etape1.jpg" imgAlt="Étape 1" description="Préparez la pâte." />
  <twig:Molecules:CarouselCard :number="2" description="Laissez reposer 30 minutes." />
#}
