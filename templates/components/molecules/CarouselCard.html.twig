<div {{ attributes.defaults({ class: 'flex flex-col h-[420px] w-[430px] max-[1500px]:w-[390px] max-[1500px]:h-[390px] max-[1100px]:w-[310px] max-[1100px]:h-[340px] max-[425px]:w-[280px] max-[425px]:h-[300px] rounded-2xl' }) }}>

{% block content %}
        {% if imgSrc %}
            <div class="flex-1 min-h-0 w-full flex items-center justify-center {{ imgClass }}">
                <twig:Atoms:Image src="{{ imgSrc }}" alt="{{ imgAlt }}" class="max-w-full max-h-full object-contain" />
            </div>
        {% endif %}
        {% if description %}
            <p class="carousel-card-description text-text text-center text-sm shrink-0 opacity-0 relative z-10">{{ description }}</p>
        {% endif %}
    {% endblock %}

</div>

{#
  Props (* = obligatoire) :
  - imgSrc      string  — URL de l'image ('')
  - imgAlt      string  — texte alternatif de l'image ('')
  - imgClass    string  — classes CSS supplémentaires sur le conteneur image ('')
  - description string  — texte descriptif de l'étape ('')

  Utilisation :
  <twig:Molecules:CarouselCard :number="1" imgSrc="/images/etape1.jpg" imgAlt="Étape 1" description="Préparez la pâte." />
  <twig:Molecules:CarouselCard :number="2" description="Laissez reposer 30 minutes." />
#}
