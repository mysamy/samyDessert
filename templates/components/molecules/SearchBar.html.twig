<section class="bg-white border-b border-slate-100 py-6">
  <div class="mx-auto max-w-7xl px-4">
    <form method="GET" action="{{ action }}" class="flex gap-3 max-w-xl">
      <input
        type="search"
        name="{{ name }}"
        value="{{ value }}"
        placeholder="{{ placeholder }}"
        class="flex-1 rounded-full border border-slate-200 px-5 py-2.5 text-sm text-text placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent"
        aria-label="{{ placeholder }}"
      >
      {% block extra_inputs %}{% endblock %}
      <button
        type="submit"
        class="inline-flex items-center gap-2 bg-accent text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-primary transition"
      >
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        {{ buttonLabel }}
      </button>
    </form>
  </div>
</section>
