<section class="bg-white border-b border-slate-100 py-6">
  <div class="container-main">
    <form method="GET" action="{{ action }}" class="flex gap-3 max-w-xl">
      <input
        type="search"
        name="{{ name }}"
        value="{{ value }}"
        placeholder="{{ placeholder }}"
        class="flex-1 rounded-full border border-slate-200 px-5 py-2.5 text-sm text-text placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-accent/40 focus:border-accent"
        aria-label="{{ placeholder }}"
      >
      {% block extra_inputs %}{% endblock %}
      <button
        type="submit"
        class="inline-flex items-center gap-2 bg-accent text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-primary transition"
      >
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        {{ buttonLabel }}
      </button>
    </form>
  </div>
</section>

{#
  Props (* = obligatoire) :
  - action*     string  — URL de soumission du formulaire
  - value       string  — valeur pré-remplie du champ ('')
  - name        string  — name du champ de recherche (q)
  - placeholder string  — placeholder du champ ('Rechercher...')
  - buttonLabel string  — libellé du bouton ('Rechercher')

  Utilisation :
  <twig:Molecules:SearchBar action="{{ path('app_produits') }}" value="{{ app.request.query.get('q') }}" />
  <twig:Molecules:SearchBar action="{{ path('app_recettes') }}" placeholder="Chercher une recette..." buttonLabel="Trouver" />
#}
