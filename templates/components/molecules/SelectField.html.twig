{% set id = this.computedId %}
{% set describedBy = this.describedBy %}
{% set isInvalid = this.effectiveInvalid %}
{% set ariaLabel = this.effectiveAriaLabel %}
{% set helpId = this.helpId %}
{% set errorId = this.errorId %}
{% set selectedValue = value %}
{% set isSelectedEmpty = (selectedValue is null or selectedValue == '') %}

<div {{ attributes.defaults({ class: 'w-full' }) }}>
  {% if label %}
    <twig:Atoms:Label
      for="{{ id }}"
      label="{{ label }}"
      :required="required"
      class="mb-1 block"
    />
  {% endif %}

  <twig:Atoms:Select
    :required="required"
    :disabled="disabled"
    :multiple="multiple"
    id="{{ id }}"
    name="{{ name }}{% if multiple %}[]{% endif %}"
    aria-describedby="{{ describedBy }}"
    aria-invalid="{{ isInvalid ? 'true' : 'false' }}"
    aria-label="{{ ariaLabel }}"
    class="{{ isInvalid ? 'border-danger focus-visible:ring-danger/40' : '' }}"
  >
    {% if placeholder and not multiple %}
      <option value="" {% if isSelectedEmpty %}selected{% endif %} {% if required %}disabled{% endif %}>
        {{ placeholder }}
      </option>
    {% endif %}

    {% for opt in options %}
      {% if opt.options is defined %}
        <optgroup label="{{ opt.label|default('') }}">
          {% for sub in opt.options %}
            <option
              value="{{ sub.value|default('') }}"
              {% if selectedValue == sub.value|default('') %}selected{% endif %}
              {% if sub.disabled|default(false) %}disabled{% endif %}
            >
              {{ sub.label|default(sub.value|default('')) }}
            </option>
          {% endfor %}
        </optgroup>
      {% else %}
        <option
          value="{{ opt.value|default('') }}"
          {% if selectedValue == opt.value|default('') %}selected{% endif %}
          {% if opt.disabled|default(false) %}disabled{% endif %}
        >
          {{ opt.label|default(opt.value|default('')) }}
        </option>
      {% endif %}
    {% endfor %}
  </twig:Atoms:Select>

  {% if help %}
    <p id="{{ helpId }}" class="mt-1 text-sm text-text-light">{{ help }}</p>
  {% endif %}

  {% if error %}
    <p id="{{ errorId }}" class="mt-1 text-sm text-danger" role="alert">{{ error }}</p>
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - name*       string      — attribut name du select
  - label*      string      — libellé du champ
  - options     array       — options { value, label, disabled? } ou groupes { label, options[] } ([])
  - value       string|null — valeur sélectionnée (null)
  - placeholder string|null — option vide initiale (null)
  - required    bool        — obligatoire (false)
  - disabled    bool        — désactivé (false)
  - multiple    bool        — sélection multiple (false)
  - error       string|null — message d'erreur (null)
  - help        string|null — texte d'aide (null)

  Utilisation :
  <twig:Molecules:SelectField
    name="pays"
    label="Pays"
    :required="true"
    :options="[{ value: 'FR', label: 'France' }, { value: 'BE', label: 'Belgique' }]"
    value="FR"
  />
#}
