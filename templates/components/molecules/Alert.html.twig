{% set variants = {
  info:    'bg-surface text-text border-border',
  success: 'bg-success-light text-success border-success',
  warning: 'bg-primary-light text-primary border-primary',
  error:   'bg-danger-light text-danger-dark border-danger'
} %}

<div
  class="rounded-md border px-4 py-3 text-sm {{ variants[type] ?? variants.info }}"
  role="alert"
  aria-live="{{ type == 'error' ? 'assertive' : 'polite' }}"
>
  {{ message }}
</div>

{#
  Props (* = obligatoire) :
  - message*    string  — texte du message
  - type        string  — niveau d'alerte : info | success | warning | error (info)

  Utilisation :
  <twig:Molecules:Alert message="Commande confirmée !" type="success" />
  <twig:Molecules:Alert message="Email ou mot de passe incorrect." type="error" />
  <twig:Molecules:Alert message="Votre panier a été mis à jour." type="info" />
  <twig:Molecules:Alert message="Stock limité." type="warning" />
#}
