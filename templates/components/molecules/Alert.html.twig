{% set variants = {
  info:    'bg-surface text-text border-border',
  success: 'bg-success-light text-success border-success',
  warning: 'bg-primary-light text-primary border-primary',
  error:   'bg-danger-light text-danger-dark border-danger'
} %}

<div
  class="rounded-md border px-4 py-3 text-sm {{ variants[type] ?? variants.info }}"
  role="alert"
  aria-live="{{ type == 'error' ? 'assertive' : 'polite' }}"
>
  {{ message }}
</div>
