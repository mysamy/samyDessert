{% set itemTitle = item.title ?? '' %}
{% set itemUrl = item.url ?? '#' %}
{% set itemImageSrc = item.imageSrc ?? '' %}
{% set itemImageAlt = item.imageAlt ?? '' %}
{% set itemRatingAriaLabel = item.ratingAriaLabel ?? '' %}
{% set itemRatingText = item.ratingText ?? '' %}
{% set itemFormattedPrice = item.formattedPrice ?? '' %}
{% set itemAddToCartUrl = item.addToCartUrl ?? '#' %}
{% set itemAddToCartLabel = item.addToCartLabel ?? 'Ajouter au panier' %}
{% set itemId = item.id ?? '' %}
{% set itemClass = item.class ?? '' %}
{% set itemRating = item.rating ?? 0 %}
{% set itemAddToCartDisabled = item.addToCartDisabled ?? false %}

<article class="product-card">
    <img
        src="{{ image }}"
        alt="Image du produit {{ title }}"
        class="product-card__image"
    >

    <div class="product-card__body">
        <h3 class="product-card__title">{{ title }}</h3>

        <div class="product-card__rating" aria-label="Note {{ rating }} sur 5">
            {% for i in 1..5 %}
                <twig:Atoms:Icon
                    name="star"
                    class="{{ i <= rating ? 'is-active' : 'is-inactive' }}"
                    decorative="true"
                />
            {% endfor %}
        </div>

        <p class="product-card__price">
            {{ price|number_format(2, ',', ' ') }} €
        </p>

        <twig:Atoms:Button
            href="{{ addToCartUrl }}"
            variant="primary"
        >
            Ajouter au panier
        </twig:Atoms:Button>
    </div>
</article>
