{# Root unique obligatoire pour les live components #}
<div {{ attributes.defaults({ class: 'relative' }) }}>
  {% if this.quantite == 0 %}

    {# Bouton initial : ajouter au panier #}
    <twig:Atoms:Button
      type="button"
      class="inline-flex items-center gap-2 rounded-full bg-accent text-white font-semibold px-3 py-2 sm:px-2 md:px-3 text-small hover:bg-primary hover:scale-105 transition-all whitespace-nowrap"
      data-action="live#action"
      data-live-action-param="ajouter"
    >
      <twig:Atoms:Icon name="cart-plus" :decorative="true" class="text-small" data-loading="hide" />
      <twig:Atoms:Spinner size="md" ariaLabel="Ajout en cours" class="hidden text-white" data-loading="show" />
      Ajouter au panier
    </twig:Atoms:Button>

  {% else %}

    {# Contrôles quantité une fois dans le panier #}
    <div class="flex items-center gap-2">
      <twig:Atoms:ButtonIcon
        name="minus"
        variant="outline"
        aria-label="Retirer une unité de {{ produitNom }}"
        data-action="live#action"
        data-live-action-param="retirer"
      />

      <span class="w-6 text-center font-semibold text-text text-small" data-loading="hide">{{ this.quantite }}</span>
      <twig:Atoms:Spinner size="md" class="hidden text-accent" data-loading="show" ariaLabel="Mise à jour" />

      <twig:Atoms:ButtonIcon
        name="plus"
        variant="filled"
        aria-label="Ajouter une unité de {{ produitNom }}"
        data-action="live#action"
        data-live-action-param="ajouter"
      />
    </div>

  {% endif %}
</div>

{#
  Props LiveProp (* = obligatoire) :
  - produitId*  int     — identifiant du produit
  - produitNom  string  — nom affiché dans les aria-label ('')

  Getter :
  - quantite    int     — quantité actuelle dans le panier (depuis la session)

  Utilisation (Live Component — se met à jour automatiquement) :
  <twig:Molecules:BoutonPanier :produitId="produit.id" produitNom="{{ produit.nom }}" />
#}
