{% set id = this.computedId %}
{% set describedBy = this.describedBy %}
{% set isInvalid = this.effectiveInvalid %}
{% set ariaLabel = this.effectiveAriaLabel %}
{% set helpId = this.helpId %}
{% set errorId = this.errorId %}

<div {{ attributes.defaults({ class: 'w-full' }) }}>
  {% if label %}
    <twig:Atoms:Label
      for="{{ id }}"
      label="{{ label }}"
      :required="required"
      class="mb-1 block"
    />
  {% endif %}

  <twig:Atoms:Textarea
    :rows="rows"
    :disabled="disabled"
    :required="required"
    :readonly="readonly"
    value="{{ value ?? '' }}"
    id="{{ id }}"
    name="{{ name }}"
    placeholder="{{ placeholder ?? '' }}"
    maxlength="{{ maxlength ?? '' }}"
    aria-describedby="{{ describedBy }}"
    aria-invalid="{{ isInvalid ? 'true' : 'false' }}"
    aria-label="{{ ariaLabel }}"
    class="{{ isInvalid ? 'border-danger' : '' }}"
  />

  {% if help %}
    <p id="{{ helpId }}" class="mt-1 text-sm text-text-light">{{ help }}</p>
  {% endif %}

  {% if error %}
    <p id="{{ errorId }}" class="mt-1 text-sm text-danger" role="alert">{{ error }}</p>
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - name*       string      — attribut name du textarea
  - label*      string      — libellé du champ
  - value       string|null — valeur pré-remplie (null)
  - placeholder string|null — placeholder (null)
  - rows        int         — nombre de lignes visibles (4)
  - required    bool        — obligatoire (false)
  - disabled    bool        — désactivé (false)
  - readonly    bool        — lecture seule (false)
  - error       string|null — message d'erreur (null)
  - help        string|null — texte d'aide (null)
  - maxlength   int|null    — longueur maximale (null)

  Utilisation :
  <twig:Molecules:TextareaField name="message" label="Votre message" :required="true" />
  <twig:Molecules:TextareaField name="description" label="Description" :rows="6" help="500 caractères max" :maxlength="500" />
  <twig:Molecules:TextareaField name="notes" label="Notes" error="{{ errors.notes }}" />
#}
