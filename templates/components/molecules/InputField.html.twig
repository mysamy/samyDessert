{% set id = this.computedId %}
{% set describedBy = this.describedBy %}
{% set isInvalid = this.effectiveInvalid %}
{% set ariaLabel = this.effectiveAriaLabel %}

<div class="w-full">
  {% if label %}
    <twig:Atoms:Label
      for="{{ id }}"
      label="{{ label }}"
      :required="required"
      :optional="optional"
      class="mb-1 block"
    />
  {% endif %}

  {% if type == 'password' and showToggle %}
    <div class="relative" data-controller="password-toggle">
      <twig:Atoms:Input
        id="{{ id }}"
        name="{{ name }}"
        type="{{ type }}"
        :value="value"
        :placeholder="placeholder"
        :required="required"
        :disabled="disabled"
        :readonly="readonly"
        :autocomplete="autocomplete"
        :inputmode="inputmode"
        :maxlength="maxlength"
        :pattern="pattern"
        aria-describedby="{{ describedBy }}"
        aria-invalid="{{ isInvalid ? 'true' : 'false' }}"
        aria-label="{{ ariaLabel }}"
        class="pr-10"
        data-password-toggle-target="input"
      />
      <button
        type="button"
        class="absolute inset-y-0 right-0 flex items-center px-3 text-text-light hover:text-text transition-colors"
        data-action="password-toggle#toggle"
        data-password-toggle-target="btn"
        aria-label="Afficher le mot de passe"
      >
        <twig:Atoms:Icon name="eye" :decorative="true" data-password-toggle-target="iconShow" />
        <twig:Atoms:Icon name="eye-slash" :decorative="true" data-password-toggle-target="iconHide" style="display:none" />
      </button>
    </div>
  {% else %}
    <twig:Atoms:Input
      id="{{ id }}"
      name="{{ name }}"
      type="{{ type }}"
      :value="value"
      :placeholder="placeholder"
      :required="required"
      :disabled="disabled"
      :readonly="readonly"
      :autocomplete="autocomplete"
      :inputmode="inputmode"
      :maxlength="maxlength"
      :pattern="pattern"
      aria-describedby="{{ describedBy }}"
      aria-invalid="{{ isInvalid ? 'true' : 'false' }}"
      aria-label="{{ ariaLabel }}"
    />
  {% endif %}

  {% if help %}
    <p id="{{ this.helpId }}" class="mt-1 text-sm text-text-light">{{ help }}</p>
  {% endif %}

  {% if error %}
    <p id="{{ this.errorId }}" class="mt-1 text-sm text-danger" role="alert">{{ error }}</p>
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - name*       string      — identifiant du champ
  - label*      string      — libellé du champ
  - type        string      — type HTML : text | email | password | tel | number… (text)
  - value       string      — valeur pré-remplie ('')
  - placeholder string      — placeholder ('')
  - required    bool        — obligatoire (false)
  - disabled    bool        — désactivé (false)
  - readonly    bool        — lecture seule (false)
  - error       string      — message d'erreur ('')
  - help        string      — texte d'aide sous le champ ('')
  - autocomplete string     — attribut autocomplete HTML ('')
  - inputmode   string      — attribut inputmode HTML ('')
  - maxlength   int|null    — longueur maximale (null)
  - pattern     string|null — motif de validation (null)

  Utilisation :
  <twig:Molecules:InputField name="email" label="Adresse email" type="email" :required="true" />
  <twig:Molecules:InputField name="prenom" label="Prénom" value="{{ prenom }}" error="{{ errors.prenom }}" />
  <twig:Molecules:InputField name="code" label="Code postal" type="text" pattern="[0-9]{5}" help="5 chiffres" />
#}
