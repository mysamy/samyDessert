{% set id = this.computedId %}
{% set describedBy = this.describedBy %}
{% set isInvalid = this.effectiveInvalid %}
{% set ariaLabel = this.effectiveAriaLabel %}

<div class="w-full">
  {% if this.label %}
<twig:Atoms:Label
  for="{{ id }}"
  label="{{ this.label }}"
  :required="this.required"
  class="mb-1 block"
/>
  {% endif %}

  <twig:Atoms:Input
    id="{{ id }}"
    name="{{ this.name }}"
    type="{{ this.type }}"
    :value="this.value"
    :placeholder="this.placeholder"
    :required="this.required"
    :disabled="this.disabled"
    :readonly="this.readonly"
    :autocomplete="this.autocomplete"
    :inputmode="this.inputmode"
    :maxlength="this.maxlength"
    :pattern="this.pattern"
    aria-describedby="{{ describedBy }}"
    aria-invalid="{{ isInvalid ? 'true' : 'false' }}"
    aria-label="{{ ariaLabel }}"
    class="{{ this.class }}"
  />

  {% if this.help %}
    <p id="{{ this.helpId }}" class="mt-1 text-sm text-slate-700">{{ this.help }}</p>
  {% endif %}

  {% if this.error %}
    <p id="{{ this.errorId }}" class="mt-1 text-sm text-red-700" role="alert">{{ this.error }}</p>
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - name*       string      — identifiant du champ
  - label*      string      — libellé du champ
  - type        string      — type HTML : text | email | password | tel | number… (text)
  - value       string      — valeur pré-remplie ('')
  - placeholder string      — placeholder ('')
  - required    bool        — obligatoire (false)
  - disabled    bool        — désactivé (false)
  - readonly    bool        — lecture seule (false)
  - error       string      — message d'erreur ('')
  - help        string      — texte d'aide sous le champ ('')
  - autocomplete string     — attribut autocomplete HTML ('')
  - inputmode   string      — attribut inputmode HTML ('')
  - maxlength   int|null    — longueur maximale (null)
  - pattern     string|null — motif de validation (null)

  Utilisation :
  <twig:Molecules:InputField name="email" label="Adresse email" type="email" :required="true" />
  <twig:Molecules:InputField name="prenom" label="Prénom" value="{{ prenom }}" error="{{ errors.prenom }}" />
  <twig:Molecules:InputField name="code" label="Code postal" type="text" pattern="[0-9]{5}" help="5 chiffres" />
#}
