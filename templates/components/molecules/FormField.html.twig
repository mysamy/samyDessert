{% set fieldId = this.computedId %}
{% set errorId = this.errorId %}

<div {{ attributes.defaults({ class: 'space-y-1' }) }}>
  <twig:Atoms:Label for="{{ fieldId }}" label="{{ label }}" :required="required" />

  {% block control %}{% endblock %}

  {% if error %}
    <p class="text-sm text-danger" id="{{ errorId }}" role="alert">
      {{ error }}
    </p>
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - label*      string      — texte du label
  - id          string|null — id HTML (génère un id aléatoire si absent)
  - required    bool        — affiche l'indicateur obligatoire (false)
  - error       string|null — message d'erreur sous le champ (null)

  Utilisation (avec block control pour injecter n'importe quel champ) :
  <twig:Molecules:FormField label="Téléphone" id="tel">
    {% block control %}
      <twig:Atoms:Input name="tel" type="tel" />
    {% endblock %}
  </twig:Molecules:FormField>
#}
