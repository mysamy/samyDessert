<dialog
  data-controller="consent-banner"
  role="alertdialog"
  aria-label="Consentement cookies"
  aria-describedby="consent-banner-message"
  {{ attributes.defaults({ class: 'fixed bottom-0 left-0 right-0 z-[100] m-0 max-w-full w-full border-t-2 border-accent/30 bg-text shadow-2xl p-0 open:flex' }) }}
>
  <div class="container-main flex flex-col sm:flex-row items-center justify-between gap-6 py-6">
    <p id="consent-banner-message" class="text-small text-white text-center sm:text-left">
      {{ message }}
      {% if policyUrl %}
        <twig:Atoms:Link href="{{ policyUrl }}" class="text-accent underline ml-1">En savoir plus</twig:Atoms:Link>
      {% endif %}
    </p>
    <div class="flex items-center gap-4 shrink-0">
      <twig:Atoms:Button
        size="md"
        class="rounded-full"
        data-action="consent-banner#accept"
      >
        {{ acceptLabel }}
      </twig:Atoms:Button>
      <twig:Atoms:Button
        variant="ghost"
        size="md"
        class="rounded-full border border-white/30 text-white hover:bg-bg/10"
        data-action="consent-banner#reject"
      >
        {{ rejectLabel }}
      </twig:Atoms:Button>
    </div>
  </div>
</dialog>

{#
  Molécule CookieBanner — bandeau RGPD non-bloquant via <dialog>.
  Utilise le controller Stimulus `consent-banner` pour afficher/cacher et stocker le consentement.

  Props :
  - message       string — texte informatif ('Ce site utilise des cookies…')
  - acceptLabel   string — libellé du bouton accepter ('Accepter')
  - rejectLabel   string — libellé du bouton refuser ('Refuser')
  - policyUrl     string — lien vers la politique de confidentialité ('')

  Utilisation :
  <twig:Molecules:CookieBanner />
  <twig:Molecules:CookieBanner policyUrl="/politique-confidentialite" />
#}