{% set titleId = id ~ '-title' %}
{% set messageId = id ~ '-message' %}

<dialog
  id="{{ id }}"
  aria-labelledby="{{ titleId }}"
  aria-describedby="{{ messageId }}"
  {{ attributes.defaults({ class: 'rounded-2xl p-8 shadow-xl w-full max-w-sm border border-border backdrop:bg-black/50' }) }}
>
  <h2 id="{{ titleId }}" class="text-h4 font-bold text-text mb-3">{{ title }}</h2>
  <p id="{{ messageId }}" class="text-text-light mb-6">{{ message|raw }}</p>
  <div class="flex gap-3 justify-end">
    <twig:Atoms:Button
      variant="secondary"
      data-dialog-close="{{ id }}"
    >
      {{ cancelLabel }}
    </twig:Atoms:Button>
    <twig:Atoms:Button
      variant="primary"
      data-dialog-confirm="{{ id }}"
      class="{% if confirmVariant == 'danger' %}bg-danger hover:bg-danger-dark{% elseif confirmVariant == 'success' %}bg-success hover:bg-success-light{% endif %}"
    >
      {{ confirmLabel }}
    </twig:Atoms:Button>
  </div>
</dialog>

{#
  Props :
  - id              string   — identifiant du dialog, doit être unique ('confirm-dialog')
  - title           string   — titre affiché en haut du dialog ('Confirmation')
  - message         string   — texte de la question ('') — peut contenir du HTML
  - confirmLabel    string   — texte du bouton de confirmation ('Confirmer')
  - cancelLabel     string   — texte du bouton d'annulation ('Annuler')
  - confirmVariant  string   — couleur du bouton confirm : danger | primary | success ('danger')

  Utilisation :
  <twig:Molecules:ConfirmDialog
    id="modal-annulation"
    title="Annuler la commande"
    message="Confirmer l'annulation de la commande <strong>CMD-2025-00001</strong> ?"
    confirmLabel="Oui, annuler"
    cancelLabel="Non, garder"
    confirmVariant="danger"
  />

  JS pour ouvrir le dialog :
  document.getElementById('modal-annulation').showModal();
#}
