{% set computedLogoAlt = logoAlt ?: brandLabel %}
<header {{ attributes.defaults({ class: 'border-b bg-bg sticky top-0 z-50' }) }} data-controller="nav-toggle">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4">

    <twig:Atoms:Link href="{{ brandHref }}" class="flex gap-3">
      {% if logoSrc %}
        <twig:Atoms:Image src="{{ logoSrc }}" alt="{{ computedLogoAlt }}" class="h-8 w-auto"/>
      {% endif %}
      {% if brandLabel %}
        <span class="text-base font-semibold">{{ brandLabel }}</span>
      {% endif %}
    </twig:Atoms:Link>

    <div class="hidden lg:flex">
      <twig:Molecules:NavigationLinks />
    </div>

    <div class="flex items-center gap-3">
      {% block actions %}{% endblock %}

      <div class="lg:hidden">
        <twig:Atoms:Button
          type="button"
          variant="ghost"
          size="sm"
          class="sm:h-10 sm:px-4 sm:text-body"
          data-action="nav-toggle#toggle"
          aria-label="Ouvrir le menu"
        >
          <twig:Atoms:Icon name="bars" :decorative="true" data-nav-toggle-target="iconOpen"/>
          <twig:Atoms:Icon name="xmark" :decorative="true" data-nav-toggle-target="iconClose" style="display:none"/>
        </twig:Atoms:Button>
      </div>
    </div>
  </div>

  <dialog
    data-nav-toggle-target="menu"
    aria-label="Menu de navigation"
    class="fixed top-16 inset-x-0 m-0 w-full max-w-full border-t border-border bg-bg p-0 z-40 shadow-md"
  >
    <div class="flex flex-col items-center py-6 gap-1">
      <twig:Molecules:NavigationLinks class="flex-col items-center gap-1" />
      {% block mobileActions %}{% endblock %}
    </div>
  </dialog>
</header>

{#
  Props (* = obligatoire) :
  - brandLabel  string      — nom de la marque affiché à côté du logo ('')
  - brandHref   string      — lien du logo/marque (/)
  - logoSrc     string|null — URL du logo SVG/image (null)
  - logoAlt     string|null — texte alt du logo (brandLabel par défaut)

  Utilisation :
  <twig:Organisms:Header brandLabel="Samy Dessert" brandHref="/" />
  <twig:Organisms:Header brandLabel="Samy Dessert" logoSrc="/logotest.svg" logoAlt="Logo Samy Dessert" brandHref="/" />
#}
