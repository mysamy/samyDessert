{% set lignes = this.lignes %}
{% set total = this.total %}

<div {{ attributes }}>
{% if lignes is empty %}

  {# Panier vide #}
  <div class="text-center py-24 text-slate-400">
    <twig:Atoms:Icon name="cart-shopping" size="3x" :decorative="true" class="mb-6 block"/>
    <p class="text-xl font-medium mb-2">Votre panier est vide.</p>
    <p class="text-sm mb-8">Découvrez nos desserts artisanaux et ajoutez-en à votre panier.</p>
    <a href="{{ path('app_produits') }}"
       class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition">
      Voir nos desserts
    </a>
  </div>

{% else %}

  {# Lignes du panier #}
  <div class="divide-y divide-slate-100 mb-8">
    {% for ligne in lignes %}
      {% set produit = ligne.produit %}
      {% set quantite = ligne.quantite %}
      {% set sousTotal = (produit.prix * quantite)|number_format(2, ',', ' ') %}

      <div class="flex items-center gap-4 py-5">

        {# Image #}
        <div class="w-20 h-20 shrink-0 rounded-lg overflow-hidden bg-surface">
          {% if produit.imageSrc %}
            <img src="{{ produit.imageSrc }}" alt="{{ produit.nom }}" class="w-full h-full object-cover">
          {% else %}
            <div class="w-full h-full flex items-center justify-center text-slate-300">
              <twig:Atoms:Icon name="image" :decorative="true" class="text-2xl"/>
            </div>
          {% endif %}
        </div>

        {# Nom + catégorie #}
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-text truncate">{{ produit.nom }}</p>
          {% if produit.categorie %}
            <p class="text-xs text-slate-400 mt-0.5">{{ produit.categorie.nom }}</p>
          {% endif %}
          <p class="text-sm text-slate-500 mt-1">{{ produit.prix|number_format(2, ',', ' ') }} € / unité</p>
        </div>

        {# Contrôles quantité (live) #}
        <div class="flex items-center gap-2 shrink-0">
          <twig:Atoms:ButtonIcon
            name="minus"
            variant="outline"
            aria-label="Retirer une unité"
            data-action="live#action"
            data-live-action-param="retirer"
            data-live-id-param="{{ produit.id }}"
          />

          <span class="w-8 text-center font-semibold text-text">{{ quantite }}</span>

          <twig:Atoms:ButtonIcon
            name="plus"
            variant="outline"
            aria-label="Ajouter une unité"
            data-action="live#action"
            data-live-action-param="ajouter"
            data-live-id-param="{{ produit.id }}"
          />
        </div>

        {# Sous-total #}
        <p class="w-24 text-right font-semibold text-text shrink-0">{{ sousTotal }} €</p>

        {# Supprimer la ligne #}
        <button
          data-action="live#action"
          data-live-action-param="supprimer"
          data-live-id-param="{{ produit.id }}"
          aria-label="Supprimer {{ produit.nom }} du panier"
          class="shrink-0 text-slate-300 hover:text-red-400 transition"
        >
          <twig:Atoms:Icon name="trash" :decorative="true" class="text-sm" />
        </button>

      </div>
    {% endfor %}
  </div>

  {# Récapitulatif + actions #}
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 divider pt-6">

    {# Vider le panier #}
    <button
      data-action="live#action"
      data-live-action-param="vider"
      class="text-sm text-slate-400 hover:text-red-400 underline transition"
    >
      Vider le panier
    </button>

    {# Total + CTA #}
    <div class="text-right">
      <p class="text-sm text-slate-500 mb-1">Total</p>
      <p class="text-3xl font-bold text-text mb-4">{{ total|number_format(2, ',', ' ') }} €</p>
      <a href="{{ path('app_commande') }}"
         class="inline-flex items-center gap-2 bg-accent text-white px-8 py-3 rounded-full font-semibold hover:bg-accent/90 transition">
        Passer commande
        <twig:Atoms:Icon name="arrow-right" :decorative="true" class="text-sm"/>
      </a>
    </div>

  </div>

{% endif %}
</div>

{#
  Props (* = obligatoire) :
  — aucune prop. Live Component auto-alimenté depuis PanierService.

  Getters :
  - lignes          array   — lignes du panier [{ produit: Produit, quantite: int }]
  - total           float   — montant total
  - nombreArticles  int     — nombre total d'articles

  LiveActions disponibles (via data-live-action-param) :
  - ajouter(id)   — ajoute 1 unité du produit
  - retirer(id)   — retire 1 unité du produit
  - supprimer(id) — supprime le produit du panier
  - vider         — vide tout le panier

  Émet 'panierUpdated' → capté par PanierBadge.

  Utilisation (Live Component — mise à jour en temps réel) :
  <twig:Organisms:PanierLive />
#}
