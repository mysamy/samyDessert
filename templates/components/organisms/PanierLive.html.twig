{% set lignes = this.lignes %}
{% set total = this.total %}

<div {{ attributes.defaults({}) }}>
{% if lignes is empty %}

  {# Panier vide #}
  <div class="text-center py-24 text-text-light">
    <twig:Atoms:Icon name="cart-shopping" size="3x" :decorative="true" class="mb-6 block"/>
    <p class="text-body font-medium mb-2">Votre panier est vide.</p>
    <p class="text-small mb-8">Découvrez nos desserts artisanaux et ajoutez-en à votre panier.</p>
    <twig:Atoms:Link href="{{ path('app_produits') }}"
      class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-full font-semibold hover:bg-accent/90 transition">
      Voir nos desserts
    </twig:Atoms:Link>
  </div>

{% else %}

  {# Lignes du panier #}
  <div class="divide-y divide-border mb-8" aria-live="polite">
    {% for ligne in lignes %}
      {% set produit = ligne.produit %}
      {% set quantite = ligne.quantite %}
      {% set sousTotal = (produit.prix * quantite)|prix %}

      <div class="flex items-center gap-4 py-5">

        {# Image #}
        <div class="w-20 h-20 shrink-0 rounded-lg overflow-hidden bg-surface">
          {% if produit.imageName %}
            <img src="{{ vich_uploader_asset(produit, 'imageFile') }}" alt="{{ produit.nom }}" class="w-full h-full object-cover">
          {% else %}
            <div class="w-full h-full flex items-center justify-center text-text-light">
              <twig:Atoms:Icon name="image" :decorative="true" class="text-h4"/>
            </div>
          {% endif %}
        </div>

        {# Nom + catégorie #}
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-text truncate">{{ produit.nom }}</p>
          {% if produit.categorie %}
            <p class="text-small text-text-light mt-0.5">{{ produit.categorie.nom }}</p>
          {% endif %}
          <p class="text-small text-text-light mt-1">{{ produit.prix|prix }} / unité</p>
        </div>

        {# Contrôles quantité (live) #}
        <div class="flex items-center gap-2 shrink-0">
          <twig:Atoms:ButtonIcon
            name="minus"
            variant="outline"
            aria-label="Retirer une unité"
            data-action="live#action"
            data-live-action-param="retirer"
            data-live-id-param="{{ produit.id }}"
          />

          <span class="w-8 text-center font-semibold text-text">{{ quantite }}</span>

          <twig:Atoms:ButtonIcon
            name="plus"
            variant="outline"
            aria-label="Ajouter une unité"
            data-action="live#action"
            data-live-action-param="ajouter"
            data-live-id-param="{{ produit.id }}"
          />
        </div>

        {# Sous-total #}
        <p class="w-24 text-right font-semibold text-text shrink-0">{{ sousTotal }}</p>

        {# Supprimer la ligne #}
        <twig:Atoms:ButtonIcon
          name="trash"
          variant="ghost"
          size="sm"
          aria-label="Supprimer {{ produit.nom }} du panier"
          data-action="live#action"
          data-live-action-param="supprimer"
          data-live-id-param="{{ produit.id }}"
        />

      </div>
    {% endfor %}
  </div>

  {# Récapitulatif + actions #}
  <div class="divider pt-6 flex flex-col gap-4">

    {# Total #}
    <div class="flex items-center justify-between">
      <p class="text-small text-text-light">Total</p>
      <p class="text-h3 font-bold text-text">{{ total|prix }}</p>
    </div>

    {# Boutons alignés #}
    <div class="flex items-center justify-between gap-3" data-controller="confirm">

      <twig:Atoms:Button
        type="button"
        variant="ghost-danger"
        size="sm"
        data-action="confirm#open"
      >
        Vider le panier
      </twig:Atoms:Button>

      {% if isPage %}
        <twig:Atoms:Link href="{{ path('app_commande') }}" variant="cta-sm">
          Passer commande
          <twig:Atoms:Icon name="arrow-right" :decorative="true" class="text-small"/>
        </twig:Atoms:Link>
      {% else %}
        <twig:Atoms:Link href="{{ path('app_panier_index') }}" variant="cta-sm">
          Voir le panier
          <twig:Atoms:Icon name="arrow-right" :decorative="true" class="text-small"/>
        </twig:Atoms:Link>
      {% endif %}

      <dialog
        data-confirm-target="dialog"
        data-action="click->confirm#closeOnBackdrop"
        class="rounded-xl shadow-xl p-6 max-w-sm w-[calc(100%-2rem)] m-auto backdrop:bg-overlay"
      >
        <h3 class="text-body font-semibold text-text mb-2">Vider le panier ?</h3>
        <p class="text-small text-text-light mb-6">Tous les articles seront supprimés. Cette action est irréversible.</p>
        <div class="flex justify-end gap-3">
          <twig:Atoms:Button type="button" variant="secondary" size="sm" data-action="confirm#close">
            Annuler
          </twig:Atoms:Button>
          <twig:Atoms:Button
            type="button"
            variant="danger"
            size="sm"
            data-action="confirm#close live#action"
            data-live-action-param="vider"
          >
            Vider le panier
          </twig:Atoms:Button>
        </div>
      </dialog>
    </div>
  </div>

  </div>

{% endif %}
</div>

{#
  Props (* = obligatoire) :
  — aucune prop. Live Component auto-alimenté depuis PanierService.

  Getters :
  - lignes          array   — lignes du panier [{ produit: Produit, quantite: int }]
  - total           float   — montant total
  - nombreArticles  int     — nombre total d'articles

  LiveActions disponibles (via data-live-action-param) :
  - ajouter(id)   — ajoute 1 unité du produit
  - retirer(id)   — retire 1 unité du produit
  - supprimer(id) — supprime le produit du panier
  - vider         — vide tout le panier

  Émet 'panierUpdated' → capté par PanierBadge.

  Utilisation (Live Component — mise à jour en temps réel) :
  <twig:Organisms:PanierLive />
#}
