{% set title = this.title %}
{% set imageSrc = this.imageSrc %}
{% set imageAlt = this.computedImageAlt %}
{% set rating = this.rating %}
{% set ratingAria = this.ratingAriaLabel %}
{% set formattedPrice = this.formattedPrice %}
{% set addToCartUrl = this.addToCartUrl %}
{% set addToCartLabel = this.addToCartLabel %}
{% set addToCartDisabled = this.addToCartDisabled %}

<article class="group flex flex-col rounded-2xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-md transition bg-white">

  {# Image #}
  <div class="relative overflow-hidden h-48 bg-secondary">
    {% if imageSrc %}
      <img
        src="{{ imageSrc }}"
        alt="{{ imageAlt }}"
        class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
        loading="lazy"
      >
    {% endif %}
  </div>

  {# Contenu #}
  <div class="flex flex-col flex-1 p-5">
    <h3 class="text-base font-bold text-text mb-1 group-hover:text-accent transition">
      {{ title }}
    </h3>

    {# Étoiles #}
    {% if rating is not null %}
      <div class="flex items-center gap-1 mb-3" aria-label="{{ ratingAria }}">
        {% for i in 1..5 %}
          <i class="fa-solid fa-star text-xs {{ rating >= i ? 'text-star' : 'text-slate-200' }}" aria-hidden="true"></i>
        {% endfor %}
      </div>
    {% endif %}

    {# Prix + bouton #}
    <div class="flex items-center justify-between gap-3 mt-auto pt-3">
      <span class="text-base font-bold text-text">{{ formattedPrice }}</span>

      {% if addToCartUrl %}
        <a
          href="{{ addToCartUrl }}"
          aria-label="Ajouter {{ title }} au panier"
          class="inline-flex items-center gap-2 rounded-full bg-accent text-white px-4 py-2 text-sm font-semibold hover:bg-primary transition"
        >
          {{ addToCartLabel }}
        </a>
      {% else %}
        <button
          type="button"
          {% if addToCartDisabled %}disabled{% endif %}
          aria-label="Ajouter {{ title }} au panier"
          class="inline-flex items-center gap-2 rounded-full bg-accent text-white px-4 py-2 text-sm font-semibold hover:bg-primary transition disabled:opacity-50 disabled:cursor-not-allowed"
        >
          {{ addToCartLabel }}
        </button>
      {% endif %}
    </div>
  </div>

</article>
