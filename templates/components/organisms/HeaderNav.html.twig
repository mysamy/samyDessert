{% set rootAttrs = attributes
  .defaults({ class: 'border-b bg-white' })
%}
{% set rootAttrs = this.class ? rootAttrs.addClass(this.class) : rootAttrs %}

<header {{ rootAttrs }}>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4">
    <twig:Atoms:Link href="{{ brandHref }}" class="flex gap-3">
      
        <twig:Atoms:Image
          src="{{ logoSrc }}"
          alt="{{ logoAlt ?: brandLabel }}"
          class="h-8 w-auto"
        />
     

      <span class="text-base font-semibold">
        {{ brandLabel }}
      </span>
    </twig:Atoms:Link>

    <nav aria-label="Navigation principale">
      <twig:Molecules:NavigationLinks />
    </nav>

    <div class="flex items-center gap-3">
      {% block actions %}{% endblock %}
    </div>
  </div>
</header>