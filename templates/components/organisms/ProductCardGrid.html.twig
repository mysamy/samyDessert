{% set id = this.id %}
{% set class = this.class %}
{% set title = this.title %}
{% set items = this.items %}

{% set hasTitle = title is not empty %}
{% set hasItems = items|length > 0 %}

{% set titleId = id ? (id ~ '-title') : 'product-card-grid-title' %}

{% set attrDefaults = {} %}
{% if id %}{% set attrDefaults = attrDefaults|merge({ id: id }) %}{% endif %}
{% if hasTitle %}{% set attrDefaults = attrDefaults|merge({ 'aria-labelledby': titleId }) %}{% endif %}

{% set baseClass = 'space-y-4' %}
{% set rootAttrs = attributes.defaults(attrDefaults) %}
{% set rootAttrs = class ? rootAttrs.addClass(class) : rootAttrs %}

<section {{ rootAttrs }}>
  {% if hasTitle %}
    <h2 id="{{ titleId }}" class="text-lg font-semibold text-slate-900">
      {{ title }}
    </h2>
  {% endif %}

  {% if hasItems %}
    <ul role="list" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {% for item in items %}
    {% set itemTitre = item.nom ?? item.title ?? item.titre ?? '' %}
    {% set itemUrl = item.url ?? (item.slug ? path('app_produit_show', { slug: item.slug }) : null) %}
    {% set itemImageSrc = item.imageSrc ?? null %}
    {% set itemRating = item.rating ?? null %}
    {% set itemPrix = item.formattedPrice ?? (item.prix ? item.prix|prix : null) %}
    {% set itemDescription = item.description ?? null %}
    {% set itemCategorieLabel = item.categorieLabel ?? item.categorie.nom ?? null %}
    {% set itemProduitId = item.id ?? null %}
    {% set itemFavori = itemProduitId ? (itemProduitId in favorisIds) : false %}
    {% set itemFavoriUrl = itemProduitId ? path('app_favori_toggle', { type: 'produit', id: itemProduitId }) : null %}

    <li>
      <twig:Molecules:DessertCard
        :titre="itemTitre"
        :url="itemUrl"
        :imageSrc="itemImageSrc"
        :rating="itemRating"
        :prix="itemPrix"
        :description="itemDescription"
        :categorieLabel="itemCategorieLabel"
        :produitId="itemProduitId"
        :favori="itemFavori"
        :favoriUrl="itemFavoriUrl"
      />
    </li>
  {% endfor %}
</ul>

  {% else %}
    <div class="rounded-lg border border-slate-200 bg-white p-6 text-slate-700">
      <p>Aucun produit à afficher.</p>
    </div>
  {% endif %}
</section>

{#
  Props (* = obligatoire) :
  - items*      array       — produits ou recettes à afficher
  - title       string|null — titre de la section (null)
  - id          string|null — identifiant HTML de la section (null)

  Chaque item doit avoir : { nom, imageSrc, prix, id, difficulte?, description?, slug? }

  Utilisation :
  <twig:Organisms:ProductCardGrid :items="produits" title="Nos produits" />
  <twig:Organisms:ProductCardGrid :items="recettes" title="Nos recettes" id="recettes" />
#}
