{% set hasTitle = title is not empty %}
{% set hasItems = items|length > 0 %}

{% set titleId = id ? (id ~ '-title') : 'product-card-grid-title' %}

{% set attrDefaults = {} %}
{% if id %}{% set attrDefaults = attrDefaults|merge({ id: id }) %}{% endif %}
{% if hasTitle %}{% set attrDefaults = attrDefaults|merge({ 'aria-labelledby': titleId }) %}{% endif %}

{% set baseClass = 'space-y-4' %}
{% set rootAttrs = attributes.defaults(attrDefaults) %}
{% set rootAttrs = class ? rootAttrs.addClass(class) : rootAttrs %}

<section {{ rootAttrs }}>
  {% if hasTitle %}
    <h2 id="{{ titleId }}" class="text-body font-semibold text-text">
      {{ title }}
    </h2>
  {% endif %}

  {% if hasItems %}
    <ul role="list" class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
  {% for item in items %}
    {% set itemTitre = item.nom ?? item.titre ?? '' %}
    {% set itemUrl = item.slug ? path(type == 'recette' ? 'app_recette_show' : 'app_produit_show', { slug: item.slug }) : null %}
    {% set itemImageSrc = item.imageName ? vich_uploader_asset(item, 'imageFile') : null %}
    {% set itemRating = type == 'produit' ? (ratingsMap[item.id] ?? null) : null %}
    {% set itemPrix = type == 'produit' ? (item.prix ? item.prix|prix : null) : null %}
    {% set itemDescription = item.description ?? null %}
    {% set itemDifficulte = type == 'recette' ? (item.difficulte ? item.difficulte.value : '') : '' %}
    {% set itemTemps = type == 'recette' ? item.temps : null %}
    {% set itemPortions = type == 'recette' ? item.portions : null %}
    {% set itemCategorieLabel = item.categorie ? item.categorie.nom : null %}
    {% set itemId = item.id ?? null %}
    {% set itemFavori = itemId ? (itemId in favorisIds) : false %}
    {% set itemFavoriUrl = itemId ? path('app_favori_toggle', { type: type, id: itemId }) : null %}

    <li>
      <twig:Molecules:DessertCard
        :titre="itemTitre"
        :url="itemUrl"
        :imageSrc="itemImageSrc"
        :rating="itemRating"
        :prix="itemPrix"
        :description="itemDescription"
        :difficulte="itemDifficulte"
        :temps="itemTemps"
        :portions="itemPortions"
        :categorieLabel="itemCategorieLabel"
        :produitId="type == 'produit' ? itemId : null"
        :favori="itemFavori"
        :favoriUrl="itemFavoriUrl"
      />
    </li>
  {% endfor %}
</ul>

  {% else %}
    <div class="rounded-lg border border-border bg-surface p-6 text-text">
      <p>Aucun {{ type == 'recette' ? 'recette' : 'produit' }} à afficher.</p>
    </div>
  {% endif %}
</section>

{#
  Props (* = obligatoire) :
  - items*      array       — produits ou recettes à afficher
  - title       string|null — titre de la section (null)
  - id          string|null — identifiant HTML de la section (null)

  Chaque item doit avoir : { nom, imageSrc, prix, id, difficulte?, description?, slug? }

  Utilisation :
  <twig:Organisms:ProductCardGrid :items="produits" title="Nos produits" />
  <twig:Organisms:ProductCardGrid :items="recettes" title="Nos recettes" id="recettes" />
#}
