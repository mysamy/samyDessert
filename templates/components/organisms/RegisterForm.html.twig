<twig:Organisms:Form
  id="{{ id }}"
  method="{{ method }}"
  action="{{ action }}"
  class="{{ class }}"
  ariaLabel="Formulaire de création de compte"
  ariaDescribedby="{{ this.hasAnyError ? this.errorSummaryId : '' }}"
>
  {% if this.hasAnyError %}
    <div id="{{ this.errorSummaryId }}" class="rounded-md border border-red-200 bg-red-50 p-4" role="alert" aria-live="polite" tabindex="-1">
      <twig:Atoms:Text
        text="{{ formError is not empty ? formError : 'La création de compte a échoué. Vérifie les informations saisies.' }}"
        class="text-sm font-medium text-red-800"
      />
    </div>
  {% endif %}

  {% if csrfToken %}
    <input type="hidden" name="_token" value="{{ csrfToken }}">
  {% endif %}

  <twig:Molecules:FormFieldGroup
    id="{{ id }}__fields"
    legend="Créer un compte"
    description="Les champs marqués obligatoire doivent être complétés."
    innerClass="space-y-4"
  >
    <twig:Molecules:InputField name="email" type="email" label="Adresse email" autocomplete="email" :required="true" value="{{ emailValue }}" error="{{ emailError }}"/>
    <twig:Molecules:InputField name="password" type="password" label="Mot de passe" autocomplete="new-password" :required="true" error="{{ passwordError }}"/>
    <twig:Molecules:InputField name="confirmPassword" type="password" label="Confirmer le mot de passe" autocomplete="new-password" :required="true" error="{{ confirmPasswordError }}"/>
  </twig:Molecules:FormFieldGroup>

  <twig:Molecules:FormActions align="end">
    <twig:Atoms:Button type="submit">{{ submitLabel }}</twig:Atoms:Button>
  </twig:Molecules:FormActions>
</twig:Organisms:Form>
