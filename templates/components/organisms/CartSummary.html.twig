{% set checkoutLabel = this.checkoutLabel %}
{% set checkoutUrl = this.checkoutUrl %}
<div id="{{ this.id }}" class="rounded-lg border border-slate-200 p-4 {{ this.class }}">
	<twig:Atoms:Text text="Récapitulatif du panier" class="text-base font-semibold text-slate-900"/>

	{% if this.empty %}
		<twig:Atoms:Text text="Votre panier est vide." class="text-sm text-slate-700"/>
	{% else %}
		<ul class="divide-y divide-slate-200">
			{% for item in this.items %}
				<li class="flex items-start justify-between py-3 gap-4">
					<div class="min-w-0">
						<twig:Atoms:Text text="{{ item.name }}" class="text-sm font-medium text-slate-900 truncate"/>
						<twig:Atoms:Text text="{{ item.quantity ~ ' × ' ~ item.price ~ this.currency }}" class="text-sm text-slate-700"/>
					</div>

					<twig:Atoms:Text text="{{ (item.quantity * item.price)|number_format(2, ',', ' ') ~ this.currency }}" class="text-sm font-medium text-slate-900"/>
				</li>
			{% endfor %}
		</ul>

		<div class="flex items-center justify-between border-t border-slate-200 pt-4">
			<twig:Atoms:Text text="Total ({{ this.totalItems }} articles)" class="text-sm font-medium text-slate-900"/>
			<twig:Atoms:Text text="{{ this.totalPrice|number_format(2, ',', ' ') ~ this.currency }}" class="text-base font-semibold text-slate-900"/>
		</div>

		{% if checkoutUrl %}
			<twig:Atoms:Button href="{{ checkoutUrl }}" class="mt-4 w-full">
				{{ checkoutLabel }}
			</twig:Atoms:Button>
		{% endif %}

	{% endif %}
</div>
