<div {{ attributes.defaults({ class: 'rounded-lg border border-border p-4 space-y-4' }) }}>
  <h2 class="text-base font-semibold text-text">Récapitulatif du panier</h2>

  {% if this.isEmpty %}
    <p class="text-sm text-text-light">Votre panier est vide.</p>
  {% else %}
    <ul class="divide-y divide-border">
      {% for item in items %}
        <li class="flex items-start justify-between gap-4 py-3">
          <div class="min-w-0">
            <p class="truncate text-sm font-medium text-text">{{ item.name }}</p>
            <p class="text-sm text-text-light">{{ item.quantity }} × {{ item.price|prix }}</p>
          </div>
          <p class="text-sm font-medium text-text">{{ (item.quantity * item.price)|prix }}</p>
        </li>
      {% endfor %}
    </ul>

    <div class="flex items-center justify-between divider pt-4">
      <p class="text-sm font-medium text-text">Total ({{ this.totalItems }} articles)</p>
      <p class="text-base font-semibold text-text">{{ this.totalPrice|prix }}</p>
    </div>

    {% if checkoutUrl %}
      <twig:Atoms:Link href="{{ checkoutUrl }}" class="mt-4 btn-cta w-full justify-center">
        {{ checkoutLabel }}
      </twig:Atoms:Link>
    {% endif %}
  {% endif %}
</div>

{#
  Props :
  - items           array       — lignes du panier [{ name, quantity, price }] ([])
  - checkoutLabel   string      — libellé du bouton ('Commander')
  - checkoutUrl     string|null — URL du checkout (null = pas de bouton)

  Getters calculés :
  - isEmpty       bool    — vrai si items est vide
  - totalItems    int     — somme des quantités
  - totalPrice    float   — somme des sous-totaux

  Classes CSS : passent par attributes.

  Utilisation :
  <twig:Organisms:CartSummary :items="panierItems" checkoutUrl="{{ path('app_commande') }}" />
#}
