<div id="{{ id }}" class="rounded-lg border border-slate-200 p-4 {{ class }}">
  <h2 class="text-base font-semibold text-slate-900">Récapitulatif du panier</h2>

  {% if this.isEmpty() %}
    <p class="text-sm text-slate-700">Votre panier est vide.</p>
  {% else %}
    <ul class="divide-y divide-slate-200">
      {% for item in items %}
        <li class="flex items-start justify-between gap-4 py-3">
          <div class="min-w-0">
            <p class="truncate text-sm font-medium text-slate-900">{{ item.name }}</p>
            <p class="text-sm text-slate-700">{{ item.quantity ~ ' × ' ~ item.price ~ currency }}</p>
          </div>
          <p class="text-sm font-medium text-slate-900">{{ (item.quantity * item.price)|number_format(2, ',', ' ') ~ currency }}</p>
        </li>
      {% endfor %}
    </ul>

    <div class="flex items-center justify-between divider pt-4">
      <p class="text-sm font-medium text-slate-900">Total ({{ this.totalItems }} articles)</p>
      <p class="text-base font-semibold text-slate-900">{{ this.totalPrice|number_format(2, ',', ' ') ~ currency }}</p>
    </div>

    {% if checkoutUrl %}
      <twig:Atoms:Link
        href="{{ checkoutUrl }}"
        class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-md bg-black px-4 py-2 text-sm font-medium text-white transition hover:opacity-90"
      >
        {{ checkoutLabel }}
      </twig:Atoms:Link>
    {% endif %}
  {% endif %}
</div>

{#
  Props (* = obligatoire) :
  - items*        array       — lignes du panier { name, quantity, price }
  - checkoutUrl   string|null — URL du bouton de commande (null = bouton masqué)
  - checkoutLabel string      — libellé du bouton de commande ('Commander')
  - currency      string      — symbole monétaire ('€')
  - id            string      — identifiant HTML ('cart-summary')

  Getters calculés :
  - isEmpty()     bool    — vrai si items est vide
  - totalItems    int     — somme des quantités
  - totalPrice    float   — somme des sous-totaux

  Utilisation :
  <twig:Organisms:CartSummary :items="panier" checkoutUrl="{{ path('app_commande_checkout') }}" />

  Chaque item : { name: string, quantity: int, price: float }
#}
