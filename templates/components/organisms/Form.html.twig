<form
  method="{{ this.effectiveMethod }}"
  {% if action %}action="{{ action }}"{% endif %}
  {% if this.computedId %}id="{{ this.computedId }}"{% endif %}
  {% if novalidate %}novalidate{% endif %}
  {% if disabled %}aria-disabled="true"{% endif %}
  {% if ariaLabel %}aria-label="{{ ariaLabel }}"{% endif %}
  {% if ariaDescribedby %}aria-describedby="{{ ariaDescribedby }}"{% endif %}
  {{ attributes.defaults({ class: '' }) }}
>
  <fieldset {% if disabled %}disabled{% endif %} class="contents">
    {% block content %}{% endblock %}
  </fieldset>
</form>

{#
  Props (* = obligatoire) :
  - action         string|null — URL de soumission (null = action courante)
  - method         string      — méthode HTTP : get | post (post)
  - id             string      — identifiant HTML ('')
  - novalidate     bool        — désactive la validation native du navigateur (false)
  - disabled       bool        — désactive tout le formulaire (false)
  - ariaLabel      string|null — aria-label du formulaire (null)
  - ariaDescribedby string|null — aria-describedby (null)

  Classes CSS : passent par attributes (merge automatique depuis l'appelant).

  Utilisation :
  <twig:Organisms:Form action="{{ path('app_contact') }}" ariaLabel="Formulaire de contact" class="max-w-md space-y-6">
    ...
  </twig:Organisms:Form>
#}
