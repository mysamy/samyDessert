<form
  method="{{ this.effectiveMethod }}"
  {% if this.effectiveAction %}action="{{ this.effectiveAction }}"{% endif %}
  {% if this.computedId %}id="{{ this.computedId }}"{% endif %}
  {% if this.novalidate %}novalidate{% endif %}
  {% if this.disabled %}aria-disabled="true"{% endif %}
  {% if this.effectiveAriaLabel %}aria-label="{{ this.effectiveAriaLabel }}"{% endif %}
  {% if this.effectiveAriaDescribedby %}aria-describedby="{{ this.effectiveAriaDescribedby }}"{% endif %}
  class="{{ this.class }}"
>
  <fieldset {% if this.disabled %}disabled{% endif %} class="contents">
    {% block content %}{% endblock %}
  </fieldset>
</form>

{#
  Props (* = obligatoire) :
  - action         string|null — URL de soumission (null = action courante)
  - method         string      — méthode HTTP : get | post (post)
  - id             string      — identifiant HTML ('')
  - novalidate     bool        — désactive la validation native du navigateur (false)
  - disabled       bool        — désactive tout le formulaire (false)
  - ariaLabel      string|null — aria-label du formulaire (null)
  - ariaDescribedby string|null — aria-describedby (null)

  Utilisation :
  <twig:Organisms:Form action="{{ path('app_contact') }}" ariaLabel="Formulaire de contact">
    {# champs du formulaire #}
  </twig:Organisms:Form>

  <twig:Organisms:Form action="{{ path('app_inscription') }}" :novalidate="true" :disabled="isSubmitting">
    {# champs #}
  </twig:Organisms:Form>
#}
