{% set baseClass = 'divider bg-slate-50' %}
{% set rootAttrs = attributes.defaults({ class: baseClass }) %}
{% if class %}{% set rootAttrs = rootAttrs.addClass(class) %}{% endif %}

<footer {{ rootAttrs }}>
  <div class="mx-auto max-w-7xl space-y-4 px-4 py-6">

    {% if brandLabel %}
      <div class="text-sm font-semibold text-slate-900">
        {{ brandLabel }}
      </div>
    {% endif %}

    <twig:Molecules:Nav
      ariaLabel="Navigation pied de page"
      :links="links"
      class="flex-wrap text-sm"
    />

    {% if legalText %}
      <div class="text-xs text-slate-600">
        {{ legalText }}
      </div>
    {% endif %}

  </div>
</footer>

{#
  Props (* = obligatoire) :
  - brandLabel  string      — nom de la marque affiché en haut du footer ('')
  - links       array       — liens de navigation { label, href } ([])
  - legalText   string|null — texte légal/copyright (null)

  Utilisation :
  <twig:Organisms:Footer
    brandLabel="Samy Dessert"
    legalText="© {{ 'now'|date('Y') }} Samy Dessert. Tous droits réservés."
    :links="[
      { label: 'Mentions légales', href: path('app_mentions') },
      { label: 'Contact', href: path('app_contact') },
    ]"
  />
#}
