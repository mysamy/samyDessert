{% set hasError = this.hasAnyError %}
{% set errorId = this.errorSummaryId %}

<twig:Organisms:Form
  id="{{ id }}"
  method="{{ method }}"
  action="{{ action }}"
  class="{{ class }}"
  ariaLabel="Formulaire d'adresse"
  ariaDescribedby="{{ hasError ? errorId : '' }}"
  data-controller="submit-once"
  data-action="submit->submit-once#submit"
>
  {% if hasError %}
    <twig:Molecules:Alert
      type="error"
      id="{{ errorId }}"
      tabindex="-1"
      message="{{ formError is not empty ? formError : 'Le formulaire contient des erreurs. Vérifie les informations saisies.' }}"
    />
  {% endif %}

  {% if csrfToken %}
    <input type="hidden" name="_token" value="{{ csrfToken }}">
  {% endif %}

  <twig:Molecules:FormFieldGroup
    id="{{ id }}__fields"
    legend="{{ legend }}"
    description="Renseigne l'adresse de livraison. Les champs obligatoires doivent être complétés."
    innerClass="space-y-4"
  >
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <twig:Molecules:InputField name="firstName" type="text" label="Prénom" autocomplete="given-name" :required="true" value="{{ firstNameValue }}" error="{{ firstNameError }}"/>
      <twig:Molecules:InputField name="lastName" type="text" label="Nom" autocomplete="family-name" :required="true" value="{{ lastNameValue }}" error="{{ lastNameError }}"/>
    </div>

    <twig:Molecules:InputField name="company" type="text" label="Société" autocomplete="organization" value="{{ companyValue }}"/>

    <twig:Molecules:InputField name="address1" type="text" label="Adresse" autocomplete="address-line1" :required="true" value="{{ address1Value }}" error="{{ address1Error }}"/>

    <twig:Molecules:InputField name="address2" type="text" label="Complément d'adresse" autocomplete="address-line2" value="{{ address2Value }}"/>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <twig:Molecules:InputField name="postalCode" type="text" label="Code postal" autocomplete="postal-code" inputmode="numeric" placeholder="75001" :required="true" value="{{ postalCodeValue }}" error="{{ postalCodeError }}"/>
      <twig:Molecules:InputField name="city" type="text" label="Ville" autocomplete="address-level2" :required="true" value="{{ cityValue }}" error="{{ cityError }}"/>
      <twig:Molecules:SelectField name="country" label="Pays" :required="true" value="{{ countryValue }}" :options="countries" error="{{ countryError }}"/>
    </div>

    <twig:Molecules:InputField name="phone" type="tel" label="Téléphone" autocomplete="tel" inputmode="tel" placeholder="06 12 34 56 78" value="{{ phoneValue }}" error="{{ phoneError }}"/>

    <twig:Molecules:TextareaField name="notes" label="Notes de livraison" placeholder="Ex: Digicode, étage, instructions…" value="{{ notesValue }}" help="Optionnel."/>
  </twig:Molecules:FormFieldGroup>

  <twig:Molecules:FormActions align="end">
    <twig:Atoms:Button type="submit" data-submit-once-target="btn">
      <span data-submit-once-target="label">{{ submitLabel }}</span>
      <twig:Atoms:Spinner size="lg" ariaLabel="Enregistrement en cours" class="hidden absolute inset-0 m-auto" data-submit-once-target="spinner" />
    </twig:Atoms:Button>
  </twig:Molecules:FormActions>
</twig:Organisms:Form>

{#
  Props (* = obligatoire) :
  - action*          string  — URL de soumission du formulaire
  - csrfToken*       string  — jeton CSRF
  - legend           string  — titre du groupe de champs ('Adresse')
  - submitLabel      string  — libellé du bouton de soumission ('Enregistrer')
  - firstNameValue*  string  — valeur prénom ('')
  - lastNameValue*   string  — valeur nom ('')
  - address1Value*   string  — valeur adresse ligne 1 ('')
  - postalCodeValue* string  — valeur code postal ('')
  - cityValue*       string  — valeur ville ('')
  - companyValue     string  — valeur société ('')
  - address2Value    string  — valeur adresse ligne 2 ('')
  - countryValue     string  — valeur pays (FR)
  - phoneValue       string  — valeur téléphone ('')
  - notesValue       string  — valeur notes ('')
  - firstNameError   string  — erreur prénom ('')
  - lastNameError    string  — erreur nom ('')
  - address1Error    string  — erreur adresse ('')
  - postalCodeError  string  — erreur code postal ('')
  - cityError        string  — erreur ville ('')
  - countryError     string  — erreur pays ('')
  - phoneError       string  — erreur téléphone ('')
  - formError        string  — erreur globale du formulaire ('')

  Utilisation :
  <twig:Organisms:AddressForm
    action="{{ path('app_adresse') }}"
    csrfToken="{{ csrf_token('address') }}"
    firstNameValue="{{ adresse.prenom }}"
  />
#}
