{% set hasError = this.hasAnyError %}
{% set errorId = this.errorSummaryId %}

<twig:Organisms:Form
  id="{{ id }}"
  action="{{ action }}"
  class="{{ class }}"
  ariaLabel="Formulaire de connexion"
  ariaDescribedby="{{ hasError ? errorId : '' }}"
  data-controller="submit-once"
  data-action="submit->submit-once#submit"
>
  {% if hasError %}
    <twig:Molecules:Alert
      type="error"
      id="{{ errorId }}"
      tabindex="-1"
      message="{{ formError is not empty ? formError : 'La connexion a échoué. Vérifie les informations saisies.' }}"
    />
  {% endif %}

  {% if csrfToken %}
    <input type="hidden" name="_csrf_token" value="{{ csrfToken }}">
  {% endif %}

  <twig:Molecules:FormFieldGroup
    id="{{ id }}__fields"
    legend="Connexion"
    description="Saisis ton adresse email et ton mot de passe."
    innerClass="space-y-4"
  >
    <twig:Molecules:InputField name="email" type="email" label="Adresse email" autocomplete="email" :required="true" value="{{ emailValue }}" error="{{ emailError }}"/>
    <twig:Molecules:InputField name="password" type="password" label="Mot de passe" autocomplete="current-password" :required="true" error="{{ passwordError }}"/>
  </twig:Molecules:FormFieldGroup>

  <twig:Molecules:CheckboxField
    id="{{ id }}__remember"
    name="_remember_me"
    label="Se souvenir de moi"
    :checked="rememberMe"
  />

  <twig:Molecules:FormActions align="end">
    <twig:Atoms:Button type="submit" data-submit-once-target="btn">
      <span data-submit-once-target="label">{{ submitLabel }}</span>
      <twig:Atoms:Spinner size="lg" ariaLabel="Connexion en cours" class="hidden absolute inset-0 m-auto" data-submit-once-target="spinner" />
    </twig:Atoms:Button>
  </twig:Molecules:FormActions>
</twig:Organisms:Form>

{#
  Props (* = obligatoire) :
  - action        string  — URL de soumission du formulaire ('')
  - csrfToken     string  — jeton CSRF Symfony ('')
  - emailValue    string  — valeur pré-remplie du champ email ('')
  - rememberMe    bool    — case "Se souvenir de moi" cochée (false)
  - submitLabel   string  — libellé du bouton ('Se connecter')
  - emailError    string  — erreur sur le champ email ('')
  - passwordError string  — erreur sur le champ mot de passe ('')
  - formError     string  — erreur globale de connexion ('')

  Utilisation :
  <twig:Organisms:LoginForm
    action="{{ path('app_connexion') }}"
    csrfToken="{{ csrf_token('authenticate') }}"
    emailValue="{{ last_username }}"
    formError="{{ error ? error.messageKey|trans({}, 'security') : '' }}"
  />
#}
