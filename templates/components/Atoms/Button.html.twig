{% set base =
  "relative inline-flex items-center gap-2 rounded-full font-normal transition duration-350
   focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent
   disabled:pointer-events-none"
%}

{% set sizes = {
  sm: "px-4 pt-[7px] pb-[5px] text-small",
  md: "px-5 pt-[9px] pb-[7px] text-body",
  lg: "px-6 pt-[11px] pb-[9px] text-body"
} %}

{% set variants = {
  primary:        "bg-accent text-white hover:bg-primary hover:scale-105",
  secondary:      "bg-surface text-text hover:bg-border hover:scale-105",
  ghost:          "bg-transparent text-text hover:bg-surface hover:scale-105",
  danger:         "bg-danger text-white hover:bg-danger-dark hover:scale-105",
  ghost-danger: "font-semibold bg-transparent text-danger border-2 border-danger hover:bg-danger hover:text-white hover:scale-105"
} %}

{% set hasLoadingLabel = loadingLabel is not empty %}

<button
  type="{{ type }}"
  {% if disabled %}disabled{% endif %}
  {% if hasLoadingLabel %}data-submit-once-loading-label="{{ loadingLabel }}"{% endif %}
  {{ attributes.defaults({
    class: base ~ ' ' ~ (sizes[size] ?? sizes.md) ~ ' ' ~ (variants[variant] ?? variants.primary)
  }) }}
>
  {% if hasLoadingLabel %}<span data-submit-once-target="label">{% endif %}
  {% block content %}{% endblock %}
  {% if hasLoadingLabel %}</span>
    <twig:Atoms:Spinner size="sm" ariaLabel="{{ loadingLabel }}" class="hidden" data-submit-once-target="spinner" />
  {% endif %}
</button>

{#
  Props (* = obligatoire) :
  - type         string  — type du bouton : button | submit | reset (button)
  - variant      string  — style visuel : primary | secondary | ghost | danger (primary)
  - size         string  — taille : sm | md | lg (md)
  - disabled     bool    — désactivé (false)
  - loadingLabel string  — texte affiché pendant le chargement JS (submit-once) ; active le wrapper label+spinner automatique ('')

  Utilisation :
  <twig:Atoms:Button>Commander</twig:Atoms:Button>
  <twig:Atoms:Button variant="secondary" size="sm">Annuler</twig:Atoms:Button>
  <twig:Atoms:Button variant="ghost" size="lg">En savoir plus</twig:Atoms:Button>
  <twig:Atoms:Button type="submit" :disabled="true">Valider</twig:Atoms:Button>
#}
