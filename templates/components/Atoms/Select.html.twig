<select
  {% if required %}required{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if multiple %}multiple{% endif %}
  {{ attributes.defaults({
    class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-small text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent aria-invalid:border-danger aria-invalid:ring-danger disabled:bg-border disabled:cursor-not-allowed"
  }) }}
>
  {% block content %}{% endblock %}
</select>

{#
  Props (* = obligatoire via attributes, pas de prop PHP requise) :
  - name*       string  — identifiant du champ (via attributes)
  - disabled    bool    — désactivé (false)
  - multiple    bool    — sélection multiple (false)
  - required    bool    — obligatoire (false)

  Utilisation :
  <twig:Atoms:Select name="statut">
    <option value="en_attente">En attente</option>
    <option value="confirmee">Confirmée</option>
  </twig:Atoms:Select>
  <twig:Atoms:Select name="pays" :required="true" :multiple="true">...</twig:Atoms:Select>
#}
