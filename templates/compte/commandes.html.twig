{% extends 'base.html.twig' %}

{% block title %}Mes commandes — Samy Dessert{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-12">

  <h1 class="text-3xl font-bold text-primary mb-8">Mes commandes</h1>

  {% for message in app.flashes('success') %}
    <twig:Molecules:Alert type="success" message="{{ message }}" class="mb-4" />
  {% endfor %}
  {% for message in app.flashes('error') %}
    <twig:Molecules:Alert type="error" message="{{ message }}" class="mb-4" />
  {% endfor %}

  {% if commandes is empty %}
    <p class="text-text-light">Vous n'avez pas encore de commande.</p>
    <twig:Atoms:Link href="{{ path('app_produits') }}" class="mt-4 inline-block text-accent">Voir nos produits</twig:Atoms:Link>
  {% else %}
    <div class="space-y-6">
      {% for commande in commandes %}
        <div class="bg-surface border border-border rounded-xl p-6 shadow-sm">

          <div class="flex items-center justify-between mb-4">
            <div>
              <span class="font-bold text-primary">{{ commande.reference ?? '#' ~ commande.id }}</span>
              <span class="text-text-light text-sm ml-3">{{ commande.dateCommande|date('d/m/Y à H:i') }}</span>
            </div>
            {% set statutVariant = commande.statut.value == 'confirmee' ? 'success' :
              (commande.statut.value == 'annulee' ? 'danger' :
              (commande.statut.value == 'livree' ? 'primary' : 'warning')) %}
            <twig:Atoms:Badge variant="{{ statutVariant }}">
              {{ commande.statut.value|replace({'_': ' '})|capitalize }}
            </twig:Atoms:Badge>
          </div>

          <table class="w-full text-sm mb-4">
            <thead>
              <tr class="text-text-light border-b border-border">
                <th class="text-left pb-2">Produit</th>
                <th class="text-center pb-2">Qté</th>
                <th class="text-right pb-2">Prix unitaire</th>
              </tr>
            </thead>
            <tbody>
              {% for ligne in commande.commandeProduits %}
                <tr class="border-b border-border last:border-0">
                  <td class="py-2">{{ ligne.produit.nom }}</td>
                  <td class="py-2 text-center">{{ ligne.quantite }}</td>
                  <td class="py-2 text-right">{{ ligne.prixUnitaire|prix }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="flex items-center justify-between">
            <span class="font-bold text-primary">Total : {{ commande.total|prix }}</span>

            {% if commande.statut.value == 'confirmee' %}
              <twig:Atoms:Button
                type="button"
                variant="danger"
                size="sm"
                data-ref="{{ commande.reference ?? '#' ~ commande.id }}"
                data-action="{{ path('app_compte_annuler_commande', {id: commande.id}) }}"
                data-token="{{ csrf_token('annuler_commande_' ~ commande.id) }}"
                onclick="ouvrirModalAnnulation(this)"
              >
                Annuler la commande
              </twig:Atoms:Button>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>

{# ── Modal confirmation annulation ───────────────────────────────────────── #}
<twig:Molecules:ConfirmDialog
  id="modal-annulation"
  title="Annuler la commande"
  message="Confirmer l'annulation de la commande <strong id='modal-ref'></strong> ?"
  confirmLabel="Oui, annuler"
  cancelLabel="Non, garder"
  confirmVariant="danger"
/>

<script>
  const dialog   = document.getElementById('modal-annulation');
  const modalRef = document.getElementById('modal-ref');
  let actionUrl  = '';
  let csrfToken  = '';

  function ouvrirModalAnnulation(btn) {
    modalRef.textContent = btn.dataset.ref;
    actionUrl  = btn.dataset.action;
    csrfToken  = btn.dataset.token;
    dialog.showModal();
  }

  document.querySelector('[data-dialog-close="modal-annulation"]').addEventListener('click', () => dialog.close());

  document.querySelector('[data-dialog-confirm="modal-annulation"]').addEventListener('click', () => {
    const form    = document.createElement('form');
    form.method   = 'POST';
    form.action   = actionUrl;
    const input   = document.createElement('input');
    input.type    = 'hidden';
    input.name    = '_token';
    input.value   = csrfToken;
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
  });

  // Fermer en cliquant sur le backdrop
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
{% endblock %}
