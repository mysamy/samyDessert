{% extends 'base.html.twig' %}

{% block title %}Adresse de livraison — Samy Dessert{% endblock %}

{% block body %}

<section class="section-alt">
  <div class="container-main">
    <h1 class="text-4xl font-bold text-text mb-2">Adresse de livraison</h1>
    <p class="text-text-light text-lg">Renseignez votre adresse pour la livraison de votre commande.</p>
  </div>
</section>

<section class="section">
  <div class="mx-auto max-w-4xl px-4">
    <twig:Atoms:Link href="{{ path('app_produits') }}" class="inline-flex items-center gap-1 text-sm text-text-light hover:text-accent transition mb-6">
      <twig:Atoms:Icon name="arrow-left" size="sm" :decorative="true" /> Retour aux desserts
    </twig:Atoms:Link>

    <twig:Organisms:AddressForm
      action="{{ path('app_commande_adresse') }}"
      csrfToken="{{ csrf_token('adresse') }}"
      legend="Adresse de livraison"
      submitLabel="Continuer vers le paiement"
      formError="{{ error ?? '' }}"
      firstNameValue="{{ values.firstName ?? '' }}"
      lastNameValue="{{ values.lastName ?? '' }}"
      address1Value="{{ values.address1 ?? '' }}"
      postalCodeValue="{{ values.postalCode ?? '' }}"
      cityValue="{{ values.city ?? '' }}"
      countryValue="{{ values.country ?? 'FR' }}"
      phoneValue="{{ values.phone ?? '' }}"
      notesValue="{{ values.notes ?? '' }}"
      firstNameError="{{ errors.firstName ?? '' }}"
      lastNameError="{{ errors.lastName ?? '' }}"
      address1Error="{{ errors.address1 ?? '' }}"
      postalCodeError="{{ errors.postalCode ?? '' }}"
      cityError="{{ errors.city ?? '' }}"
    />
  </div>
</section>

{% endblock %}
