{% extends 'base.html.twig' %}

{% block title %}Passer commande — SamyDessert{% endblock %}

{% block body %}

<section class="section-alt">
  <div class="container-main text-center">
    <h1 class="text-title font-bold text-text mb-2">Passer commande</h1>
    <p class="text-text-light text-body">Vérifiez votre commande avant de procéder au paiement.</p>
  </div>
</section>

<section class="section">
  <div class="mx-auto max-w-4xl px-4">

    {# Navigation retour #}
    <div class="mb-8">
      <twig:Atoms:Link href="{{ path('app_produits') }}" class="inline-flex items-center gap-1 text-small text-text-light hover:text-accent hover:underline transition">
        <twig:Atoms:Icon name="arrow-left" size="sm" :decorative="true" /> Continuer mes achats
      </twig:Atoms:Link>
    </div>

    {# Adresse de livraison #}
    {% if adresse is defined and adresse is not empty %}
      <div class="mb-10 rounded-md border border-border p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-body font-bold text-text">Adresse de livraison</h2>
          <twig:Atoms:Link href="{{ path('app_commande_adresse') }}" class="text-small text-accent hover:underline transition">Modifier</twig:Atoms:Link>
        </div>
        <p class="text-text">{{ adresse.firstName }} {{ adresse.lastName }}</p>
        <p class="text-text-light text-small">{{ adresse.address1 }}</p>
        <p class="text-text-light text-small">{{ adresse.postalCode }} {{ adresse.city }}{% if adresse.country != 'FR' %}, {{ adresse.country }}{% endif %}</p>
        {% if adresse.phone %}
          <p class="text-text-light text-small mt-1">{{ adresse.phone }}</p>
        {% endif %}
        {% if adresse.notes %}
          <p class="text-text-light text-small mt-1 italic">{{ adresse.notes }}</p>
        {% endif %}
      </div>
    {% endif %}

    {# Récapitulatif du panier #}
    <div class="mb-10">
      <h2 class="text-body font-bold text-text mb-4">Récapitulatif</h2>
      <div class="divide-y divide-border border border-border rounded-md overflow-hidden">
        {% for ligne in lignes %}
          <div class="flex items-center justify-between px-5 py-4">
            <div>
              <p class="font-semibold text-text">{{ ligne.produit.nom }}</p>
              <p class="text-small text-text-light">{{ ligne.produit.prix|prix }} × {{ ligne.quantite }}</p>
            </div>
            <p class="font-bold text-text">{{ (ligne.produit.prix * ligne.quantite)|prix }}</p>
          </div>
        {% endfor %}
        <div class="flex items-center justify-between px-5 py-4 bg-surface">
          <p class="font-bold text-text">Total</p>
          <p class="text-subtitle font-bold text-accent">{{ total|prix }}</p>
        </div>
      </div>
    </div>

    {# Bouton paiement Stripe #}
    <twig:Organisms:Form
      action="{{ path('app_commande_paiement') }}"
      ariaLabel="Formulaire de paiement"
      data-controller="submit-once"
      data-action="submit->submit-once#submit"
    >
      <input type="hidden" name="_token" value="{{ csrf_token('commande') }}">
      <twig:Atoms:Button
        type="submit"
        class="mx-auto flex items-center justify-center gap-3 bg-accent text-white px-8 py-4 rounded-full text-body font-semibold hover:bg-primary hover:scale-105 transition"
        data-submit-once-target="btn"
      >
        <span class="flex items-center gap-3" data-submit-once-target="label">
          <twig:Atoms:Icon name="lock" :decorative="true" class="text-small"/>
          Payer {{ total|prix }} en toute sécurité
        </span>
        <twig:Atoms:Spinner size="lg" ariaLabel="Paiement en cours" class="hidden absolute inset-0 m-auto" data-submit-once-target="spinner" />
      </twig:Atoms:Button>
    </twig:Organisms:Form>

    <p class="text-center text-small text-text-light mt-4">
      <twig:Atoms:Icon name="stripe" variant="brands" size="lg" :decorative="true"/>
      Paiement sécurisé par Stripe
    </p>

  </div>
</section>

{% endblock %}
