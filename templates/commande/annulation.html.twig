{% extends 'base.html.twig' %}

{% block title %}Paiement annulé — Samy Dessert{% endblock %}

{% block body %}

<section class="py-24 bg-white text-center">
  <div class="mx-auto max-w-lg px-4">
    <div class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <i class="fa-solid fa-xmark text-3xl text-red-400" aria-hidden="true"></i>
    </div>
    <h1 class="text-3xl font-bold text-text mb-3">Paiement annulé</h1>
    <p class="text-text-light mb-8">Votre paiement a été annulé. Votre panier est conservé.</p>
    <twig:Atoms:Link href="{{ path('app_panier') }}" class="btn-cta">
      Retour au panier
    </twig:Atoms:Link>
  </div>
</section>

{% endblock %}
