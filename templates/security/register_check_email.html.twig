{% extends 'base.html.twig' %}

{% block title %}Vérifiez votre email — SamyDessert{% endblock %}

{% block body %}
<section class="min-h-[80vh] flex items-center justify-center bg-bg py-16 px-4">
  <div class="w-full max-w-sm sm:max-w-lg md:max-w-2xl text-center">
    <div class="bg-surface rounded-lg shadow-card border border-border p-8 sm:p-12 md:p-16">
      <p class="text-display mb-6" aria-hidden="true">📬</p>
      <h1 class="text-title font-bold text-text mb-3">Vérifiez votre email</h1>
      <p class="text-text-light mb-2">
        Un email de confirmation a été envoyé à <strong>{{ email }}</strong>.
      </p>
      <p class="text-text-light text-small">
        Cliquez sur le lien dans l'email pour activer votre compte.
      </p>
    </div>
  </div>
</section>
{% endblock %}