{% extends 'base.html.twig' %}

{% block title %}Vérifiez votre email — SamyDessert{% endblock %}

{% block body %}
<section class="min-h-[80vh] flex items-center justify-center bg-bg py-16 px-4">
  <div class="w-full max-w-md text-center">
    <div class="bg-surface rounded-2xl shadow-sm border border-border p-10">
      <p class="text-5xl mb-6" aria-hidden="true">📬</p>
      <h1 class="text-2xl font-bold text-text mb-3">Vérifiez votre email</h1>
      <p class="text-text-light mb-2">
        Un email de confirmation a été envoyé à <strong>{{ email }}</strong>.
      </p>
      <p class="text-text-light text-sm">
        Cliquez sur le lien dans l'email pour activer votre compte.
      </p>
    </div>
  </div>
</section>
{% endblock %}