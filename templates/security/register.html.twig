{% extends 'base.html.twig' %}

{% block title %}Créer un compte — SamyDessert{% endblock %}

{% block body %}

<section class="min-h-[80vh] flex items-center justify-center bg-bg py-16 px-4">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-h1 font-bold text-text mb-1">Créer un compte</h1>
      <p class="text-text-light text-small">Rejoignez-nous pour commander et suivre vos commandes.</p>
    </div>

    <div class="bg-surface rounded-lg shadow-card border border-border p-8">

      <twig:Organisms:RegisterForm
        action="{{ path('app_register') }}"
        csrfToken="{{ csrf_token('register') }}"
        prenomValue="{{ values.prenom ?? '' }}"
        nomValue="{{ values.nom ?? '' }}"
        emailValue="{{ values.email ?? '' }}"
        formError="{{ error ?? '' }}"
        class="flex flex-col gap-5"
      />

      <p class="mt-6 text-center text-small text-text-light">
        Déjà un compte ?
        <twig:Atoms:Link href="{{ path('app_login') }}" class="text-accent font-medium underline">Se connecter</twig:Atoms:Link>
      </p>

    </div>
  </div>
</section>

{% endblock %}
