{% extends 'base.html.twig' %}

{% block title %}Lien invalide — Samy Dessert{% endblock %}

{% block body %}
<section class="min-h-[80vh] flex items-center justify-center bg-bg py-16 px-4">
  <div class="w-full max-w-md text-center">
    <div class="bg-surface rounded-2xl shadow-sm border border-border p-10">
      <p class="text-5xl mb-6" aria-hidden="true">❌</p>
      <h1 class="text-2xl font-bold text-text mb-3">Lien invalide</h1>
      <p class="text-text-light mb-6">
        Ce lien de confirmation est invalide ou a déjà été utilisé.
      </p>
      <twig:Atoms:Link href="{{ path('app_register') }}" class="text-accent font-medium text-sm">
        Créer un nouveau compte
      </twig:Atoms:Link>
    </div>
  </div>
</section>
{% endblock %}