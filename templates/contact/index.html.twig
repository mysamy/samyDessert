{% extends 'base.html.twig' %}

{% block title %}Contactez-nous — SamyDessert{% endblock %}

{% block body %}

<section class="section-alt">
  <div class="container-main">
    <h1 class="text-h1 font-bold text-text mb-2">Contactez-nous</h1>
    <p class="text-text-light text-body">Une question, une commande sur mesure ? Écrivez-nous.</p>
  </div>
</section>

<section class="section">
  <div class="mx-auto max-w-2xl px-4">

    {% for message in app.flashes('success') %}
      <twig:Molecules:Alert type="success" message="{{ message }}" class="mb-8" />
    {% endfor %}

    <twig:Organisms:ContactForm action="{{ path('app_contact') }}" />

  </div>
</section>

{# Infos pratiques #}
<section class="py-12 bg-surface">
  <div class="container-main">
    <div class="grid gap-8 sm:grid-cols-3 text-center">

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary-light text-primary text-body">
          <twig:Atoms:Icon name="location-dot" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Adresse</h3>
        <p class="text-text-light text-small">12 rue de la Pâtisserie<br>75001 Paris</p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary-light text-primary text-body">
          <twig:Atoms:Icon name="phone" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Téléphone</h3>
        <twig:Atoms:Link href="tel:+33123456789" class="text-accent text-small">
          01 23 45 67 89
        </twig:Atoms:Link>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary-light text-primary text-body">
          <twig:Atoms:Icon name="clock" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Horaires</h3>
        <p class="text-text-light text-small">Lun – Sam : 9h – 19h<br>Dimanche : fermé</p>
      </div>

    </div>
  </div>
</section>

{% endblock %}
