{% extends 'base.html.twig' %}

{% block title %}Contactez-nous — Samy Dessert{% endblock %}

{% block body %}

<section class="section-alt">
  <div class="container-main">
    <h1 class="text-4xl font-bold text-text mb-2">Contactez-nous</h1>
    <p class="text-text-light text-lg">Une question, une commande sur mesure ? Écrivez-nous.</p>
  </div>
</section>

<section class="py-16 bg-white">
  <div class="mx-auto max-w-2xl px-4">

    {% for message in app.flashes('success') %}
      <twig:Molecules:Alert type="success" message="{{ message }}" class="mb-8" />
    {% endfor %}

    {# TEST — à supprimer #}
    <div class="space-y-4 mb-8">
      <twig:Molecules:Alert type="info" message="Votre message a bien été envoyé." />
      <twig:Molecules:Alert type="success" title="Commande confirmée" message="Vous recevrez un email de confirmation." />
      <twig:Molecules:Alert type="warning" message="Stock limité, commandez vite." />
      <twig:Molecules:Alert type="error" title="Paiement refusé" message="Vérifiez les informations de votre carte." />
    </div>

    <twig:Organisms:Form
      action="/contact"
      ariaLabel="Formulaire de contact"
      class="flex flex-col gap-6"
      data-controller="submit-once"
      data-action="submit->submit-once#submit"
    >
      <twig:block name="content">

        {# Nom + Email côte à côte sur grand écran #}
        <div class="grid gap-4 sm:grid-cols-2">
          <twig:Molecules:InputField
            name="nom"
            label="Nom"
            placeholder="Votre nom"
            :required="true"
            autocomplete="name"
          />
          <twig:Molecules:InputField
            name="email"
            type="email"
            label="Email"
            placeholder="votre@email.fr"
            :required="true"
            autocomplete="email"
          />
        </div>

        {# Sujet #}
        <twig:Molecules:SelectField
          name="sujet"
          label="Sujet"
          placeholder="Choisissez un sujet"
          :required="true"
          :options="[
            { value: 'commande', label: 'Commande sur mesure' },
            { value: 'info',     label: 'Renseignement produit' },
            { value: 'livraison',label: 'Livraison' },
            { value: 'autre',    label: 'Autre' }
          ]"
        />

        {# Message #}
        <twig:Molecules:TextareaField
          name="message"
          label="Message"
          placeholder="Décrivez votre demande..."
          :required="true"
          :rows="6"
        />

        {# Submit #}
        <div class="flex justify-end">
          <twig:Atoms:Button
            type="submit"
            class="btn-cta"
            data-submit-once-target="btn"
          >
            <span class="flex items-center gap-2" data-submit-once-target="label">
              Envoyer le message
              <twig:Atoms:Icon name="paper-plane" :decorative="true"/>
            </span>
            <twig:Atoms:Spinner size="sm" ariaLabel="Envoi en cours" class="hidden" data-submit-once-target="spinner" />
          </twig:Atoms:Button>
        </div>

      </twig:block>
    </twig:Organisms:Form>

  </div>
</section>

{# Infos pratiques #}
<section class="py-12 bg-surface">
  <div class="container-main">
    <div class="grid gap-8 sm:grid-cols-3 text-center">

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-surface text-accent text-xl">
          <twig:Atoms:Icon name="location-dot" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Adresse</h3>
        <p class="text-text-light text-sm">12 rue de la Pâtisserie<br>75001 Paris</p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-surface text-accent text-xl">
          <twig:Atoms:Icon name="phone" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Téléphone</h3>
        <twig:Atoms:Link href="tel:+33123456789" class="text-accent text-sm hover:underline">
          01 23 45 67 89
        </twig:Atoms:Link>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-surface text-accent text-xl">
          <twig:Atoms:Icon name="clock" :decorative="true"/>
        </div>
        <h3 class="font-semibold text-text">Horaires</h3>
        <p class="text-text-light text-sm">Lun – Sam : 9h – 19h<br>Dimanche : fermé</p>
      </div>

    </div>
  </div>
</section>

{% endblock %}
