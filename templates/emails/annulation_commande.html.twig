{% apply inline_css(source('@styles/email.css')) %}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Annulation de commande</title>
</head>
<body>
  <div class="email">

    <div class="email__header">
      <h1>Votre commande a été annulée</h1>
    </div>

    <div class="email__body">
      <p>Bonjour {% if commande.utilisateur.prenom %}{{ commande.utilisateur.prenom }}{% else %}{{ commande.utilisateur.email }}{% endif %},</p>
      <p>Nous vous confirmons l'annulation de votre commande.</p>

      {% if commande.reference %}
        <div class="email__reference">
          Référence annulée
          <strong>{{ commande.reference }}</strong>
        </div>
      {% endif %}

      <table class="email__table">
        <thead>
          <tr>
            <th>Produit</th>
            <th>Qté</th>
            <th>Prix unitaire</th>
          </tr>
        </thead>
        <tbody>
          {% for ligne in commande.commandeProduits %}
            <tr>
              <td>{{ ligne.produit.nom }}</td>
              <td>{{ ligne.quantite }}</td>
              <td>{{ ligne.prixUnitaire|prix }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <p class="email__total">Total de la commande annulée : {{ commande.total|prix }}</p>

      <p>Pour toute question concernant un remboursement, contactez-nous à l'adresse de support.</p>

      <p>À bientôt chez SamyDessert !</p>
    </div>

    <div class="email__footer">
      SamyDessert · Pâtisseries artisanales
    </div>

  </div>
</body>
</html>
{% endapply %}
