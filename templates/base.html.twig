<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}SamyDessert{% endblock %}</title>

    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('vendor/@fortawesome/fontawesome-free/css/all.css') }}">
      <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
      {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
  </head>
  <body class="text-body">
  <div data-controller="cart-sidebar">

    <twig:Organisms:Header
      brandLabel="SamyDessert"
      brandHref="/"
      logoSrc="/logotest.svg"
      logoAlt="SamyDessert"
    >
      <twig:block name="cartSlot">
        <button
          type="button"
          class="group flex items-center gap-2 text-primary hover:text-accent transition-colors"
          aria-label="Ouvrir le panier"
          data-action="cart-sidebar#open"
        >
          <div class="btn-cart relative w-fit transition-transform group-hover:scale-110">
            <twig:Atoms:Icon name="bag-shopping" size="3x" :decorative="true" />
            <twig:Atoms:PanierBadge class="absolute top-1/2 left-1/2 [translate:-50%_-35%]" />
          </div>
          <span>Panier</span>
        </button>
      </twig:block>
      <twig:block name="desktopActions">
        {% if app.user %}
          <div class="relative" data-controller="dropdown">
            <button data-action="dropdown#toggle"
                    class="flex items-center gap-2 text-sm font-medium text-text hover:text-accent transition">
              <twig:Atoms:Icon name="circle-user" size="lg" :decorative="true" />
              {{ app.user.prenom ?? app.user.userIdentifier }}
              <twig:Atoms:Icon name="chevron-down" size="xs" :decorative="true" />
            </button>
            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-44 bg-surface border border-border rounded-xl shadow-lg z-50 overflow-hidden text-sm">
              <twig:Atoms:Link href="{{ path('app_compte_index') }}"
                class="flex items-center gap-2 px-4 py-3 text-sm hover:bg-bg transition">
                <twig:Atoms:Icon name="user" size="sm" :decorative="true" /> Mon compte
              </twig:Atoms:Link>
              {% if is_granted('ROLE_ADMIN') %}
                <twig:Atoms:Link href="{{ path('admin') }}"
                  class="flex items-center gap-2 px-4 py-3 text-sm hover:bg-bg transition border-t border-border">
                  <twig:Atoms:Icon name="screwdriver-wrench" size="sm" :decorative="true" /> Administration
                </twig:Atoms:Link>
              {% endif %}
              <twig:Atoms:Link href="{{ path('_logout_main') }}"
                class="flex items-center gap-2 px-4 py-3 text-sm text-danger hover:bg-danger-light transition border-t border-border">
                <twig:Atoms:Icon name="right-from-bracket" size="sm" :decorative="true" /> Se déconnecter
              </twig:Atoms:Link>
            </div>
          </div>
        {% else %}
          <twig:Atoms:Link href="{{ path('app_login') }}" class="btn-cta-sm">Se connecter</twig:Atoms:Link>
        {% endif %}
      </twig:block>
      <twig:block name="mobileActions">
        <div class="flex flex-col items-center gap-1 border-t border-surface w-full pt-3">
          {% if app.user %}
            <twig:Atoms:Link href="{{ path('app_compte_index') }}" class="flex items-center gap-2 px-2 py-2 text-text hover:text-accent">
              <twig:Atoms:Icon name="user" size="sm" :decorative="true" /> Mon compte
            </twig:Atoms:Link>
            {% if is_granted('ROLE_ADMIN') %}
              <twig:Atoms:Link href="{{ path('admin') }}" class="flex items-center gap-2 px-2 py-2 text-text hover:text-accent">
                <twig:Atoms:Icon name="screwdriver-wrench" size="sm" :decorative="true" /> Administration
              </twig:Atoms:Link>
            {% endif %}
            <twig:Atoms:Link href="{{ path('_logout_main') }}" class="flex items-center gap-2 px-2 py-2 text-red-600 hover:text-red-700">
              <twig:Atoms:Icon name="right-from-bracket" size="sm" :decorative="true" /> Se déconnecter
            </twig:Atoms:Link>
          {% else %}
            <twig:Atoms:Link href="/connexion" class="btn-cta-sm mt-1">Se connecter</twig:Atoms:Link>
          {% endif %}
        </div>
      </twig:block>
    </twig:Organisms:Header>

    <main>
      {% block body %}{% endblock %}
    </main>

    <twig:Molecules:CookieBanner />

    {# Sidebar panier — dialog modal (top-layer, focus trap, Escape natif) #}
    <dialog
      data-cart-sidebar-target="panel"
      data-action="cancel->cart-sidebar#handleCancel click->cart-sidebar#handleBackdropClick"
      class="cart-sidebar bg-bg translate-x-full transition-transform duration-300"
    >
      <div class="flex items-center justify-between px-6 py-4 border-b border-border">
        <h2 class="text-lg font-semibold text-text">Mon panier</h2>
        <button
          type="button"
          class="text-text-light hover:text-text transition-colors"
          aria-label="Fermer le panier"
          data-action="cart-sidebar#close"
        >
          <twig:Atoms:Icon name="xmark" size="lg" :decorative="true" />
        </button>
      </div>
      <div class="flex-1 overflow-y-auto px-6 py-4">
        <twig:Organisms:PanierLive />
      </div>
    </dialog>

    <twig:Organisms:Footer
      brandLabel="SamyDessert"
      tagline="Artisan pâtissier · Fait maison"
      legalText="© {{ 'now'|date('Y') }} SamyDessert. Tous droits réservés."
      :links="[
        { label: 'Accueil', href: path('app_home') },
        { label: 'Desserts et prix', href: path('app_produits') },
        { label: 'Recettes', href: path('app_recettes') },
        { label: 'Contactez-moi', href: path('app_contact') }
      ]"
      :legalLinks="[
        { label: 'Mentions légales', href: path('app_mentions_legales') }
      ]"
      :socialLinks="[
        { label: 'Instagram', href: '#', icon: 'instagram' },
        { label: 'Facebook', href: '#', icon: 'facebook' }
      ]"
    />

  </div>
  </body>
</html>
