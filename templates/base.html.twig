<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8">
    <title>{% block title %}Samy Dessert{% endblock %}</title>

    {% block stylesheets %}
      <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
      <link rel="stylesheet" href="{{ asset('vendor/@fortawesome/fontawesome-free/css/all.css') }}">
    {% endblock %}

    {% block javascripts %}
      {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
  </head>
  <body class="text-body">

    <twig:Organisms:Header
      brandLabel="Samy Dessert"
      brandHref="/"
      logoSrc="/logotest.svg"
      logoAlt="Samy Dessert"
    >
      <twig:block name="actions">
        <twig:Atoms:Link href="/panier" class="flex items-center gap-1.5">
          Panier
          <twig:Atoms:PanierBadge />
        </twig:Atoms:Link>
        {% if app.user %}
          <div class="relative" data-controller="dropdown">
            <button data-action="dropdown#toggle"
                    class="flex items-center gap-2 text-sm font-medium text-text hover:text-accent transition">
              <twig:Atoms:Icon name="circle-user" size="lg" :decorative="true" />
              {{ app.user.prenom ?? app.user.userIdentifier }}
              <twig:Atoms:Icon name="chevron-down" size="xs" :decorative="true" />
            </button>
            <div data-dropdown-target="menu"
                 class="hidden absolute right-0 mt-2 w-44 bg-white border border-surface rounded-xl shadow-lg z-50 overflow-hidden text-sm">
              <twig:Atoms:Link href="{{ path('app_compte_index') }}"
                class="flex items-center gap-2 px-4 py-3 text-sm hover:bg-surface transition">
                <twig:Atoms:Icon name="user" size="sm" :decorative="true" /> Mon compte
              </twig:Atoms:Link>
              {% if is_granted('ROLE_ADMIN') %}
                <twig:Atoms:Link href="{{ path('admin') }}"
                  class="flex items-center gap-2 px-4 py-3 text-sm hover:bg-surface transition border-t border-surface">
                  <twig:Atoms:Icon name="screwdriver-wrench" size="sm" :decorative="true" /> Administration
                </twig:Atoms:Link>
              {% endif %}
              <twig:Atoms:Link href="{{ path('_logout_main') }}"
                class="flex items-center gap-2 px-4 py-3 text-sm text-red-600 hover:bg-red-50 transition border-t border-surface">
                <twig:Atoms:Icon name="right-from-bracket" size="sm" :decorative="true" /> Se déconnecter
              </twig:Atoms:Link>
            </div>
          </div>
        {% else %}
          <twig:Atoms:Link href="/connexion">Se connecter</twig:Atoms:Link>
        {% endif %}
      </twig:block>
    </twig:Organisms:Header>

    <main>
      {% block body %}{% endblock %}
    </main>

    <twig:Organisms:Footer
      brandLabel="Samy Dessert"
      legalText="© {{ 'now'|date('Y') }} Samy Dessert. Tous droits réservés."
      :links="[
        { label: 'Accueil', href: '/' },
        { label: 'Desserts et prix', href: '/produits' },
        { label: 'Recettes', href: '/recettes' },
        { label: 'Contactez-moi', href: '/contact' }
      ]"
    />

  </body>
</html>
