{% apply inline_css(source('@styles/pdf.css')) %}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Facture {{ commande.reference ?? commande.id }}</title>
</head>
<body>

  <h1>Samy Dessert</h1>
  <div class="pdf__subtitle">Pâtisseries artisanales</div>

  <div class="pdf__row">
    <div>
      <div class="pdf__block-title">Facture</div>
      <div>Date : {{ commande.dateCommande|date('d/m/Y') }}</div>
      {% if commande.reference %}
        <div class="pdf__reference">{{ commande.reference }}</div>
      {% endif %}
    </div>
    <div class="pdf__col-right">
      <div class="pdf__block-title">Client</div>
      <div>{{ commande.utilisateur.prenom ?? '' }} {{ commande.utilisateur.nom ?? commande.utilisateur.email }}</div>
      <div>{{ commande.utilisateur.email }}</div>
      {% if commande.adresseLivraison %}
        <div>{{ commande.adresseLivraison }}</div>
        <div>{{ commande.codePostal }} {{ commande.ville }}</div>
      {% endif %}
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Produit</th>
        <th>Quantité</th>
        <th>Prix unitaire</th>
        <th>Sous-total</th>
      </tr>
    </thead>
    <tbody>
      {% for ligne in commande.commandeProduits %}
        <tr>
          <td>{{ ligne.produit.nom }}</td>
          <td>{{ ligne.quantite }}</td>
          <td>{{ ligne.prixUnitaire|prix }}</td>
          <td>{{ (ligne.quantite * ligne.prixUnitaire)|prix }}</td>
        </tr>
      {% endfor %}
      <tr>
        <td colspan="3" class="pdf__total">Total</td>
        <td class="pdf__total">{{ commande.total|prix }}</td>
      </tr>
    </tbody>
  </table>

  {% if commande.notes %}
    <p><strong>Notes :</strong> {{ commande.notes }}</p>
  {% endif %}

  <div class="pdf__footer">
    Samy Dessert · Pâtisseries artisanales · Merci pour votre confiance !
  </div>

</body>
</html>
{% endapply %}
