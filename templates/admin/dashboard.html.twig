{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}
<div style="padding: 1.5rem;">

  {# ── Cartes de stats ── #}
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem;">

    <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow-card);">
      <div style="background: var(--color-warning-light); border-radius: var(--radius-sm); padding: 0.75rem;">
        <i class="fa fa-cake-candles" style="color: var(--color-warning); font-size: 1.5rem;"></i>
      </div>
      <div>
        <div style="font-size: var(--text-h3); font-weight: 700; color: var(--color-text);">{{ nbProduits }}</div>
        <div style="color: var(--color-text-light); font-size: var(--text-small);">Produits</div>
      </div>
    </div>

    <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow-card);">
      <div style="background: var(--color-success-light); border-radius: var(--radius-sm); padding: 0.75rem;">
        <i class="fa fa-bag-shopping" style="color: var(--color-success); font-size: 1.5rem;"></i>
      </div>
      <div>
        <div style="font-size: var(--text-h3); font-weight: 700; color: var(--color-text);">{{ nbCommandes }}</div>
        <div style="color: var(--color-text-light); font-size: var(--text-small);">Commandes</div>
      </div>
    </div>

    <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; display: flex; align-items: center; gap: 1rem; box-shadow: var(--shadow-card);">
      <div style="background: var(--color-accent-light); border-radius: var(--radius-sm); padding: 0.75rem;">
        <i class="fa fa-users" style="color: var(--color-accent); font-size: 1.5rem;"></i>
      </div>
      <div>
        <div style="font-size: var(--text-h3); font-weight: 700; color: var(--color-text);">{{ nbUtilisateurs }}</div>
        <div style="color: var(--color-text-light); font-size: var(--text-small);">Utilisateurs</div>
      </div>
    </div>

  </div>

  {# ── Deux colonnes : dernières commandes + calendrier ── #}
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">

    {# Colonne gauche : dernières commandes #}
    <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; box-shadow: var(--shadow-card);">
      <h3 style="margin: 0 0 1rem; font-size: var(--text-small); font-weight: 600; color: var(--color-text);">
        <i class="fa fa-clock-rotate-left" style="margin-right: 0.5rem; color: var(--color-text-light);"></i>
        Dernières commandes
      </h3>
      {% if dernieresCommandes is empty %}
        <p style="color: var(--color-text-light); font-size: var(--text-small);">Aucune commande pour le moment.</p>
      {% else %}
        <table style="width: 100%; border-collapse: collapse; font-size: var(--text-small);">
          <thead>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <th style="text-align: left; padding: 0.5rem 0.25rem; color: var(--color-text-light); font-weight: 500;">Référence</th>
              <th style="text-align: left; padding: 0.5rem 0.25rem; color: var(--color-text-light); font-weight: 500;">Client</th>
              <th style="text-align: right; padding: 0.5rem 0.25rem; color: var(--color-text-light); font-weight: 500;">Total</th>
              <th style="text-align: right; padding: 0.5rem 0.25rem; color: var(--color-text-light); font-weight: 500;">Statut</th>
            </tr>
          </thead>
          <tbody>
            {% for commande in dernieresCommandes %}
              <tr style="border-bottom: 1px solid var(--color-border);">
                <td style="padding: 0.625rem 0.25rem; font-weight: 500;">{{ commande.reference ?? '#' ~ commande.id }}</td>
                <td style="padding: 0.625rem 0.25rem; color: var(--color-text-light);">
                  {{ commande.utilisateur.prenom ?? '' }} {{ commande.utilisateur.nom ?? commande.utilisateur.email }}
                </td>
                <td style="padding: 0.625rem 0.25rem; text-align: right;">{{ commande.total|prix }}</td>
                <td style="padding: 0.625rem 0.25rem; text-align: right;">
                  {% set statut = commande.statut.value %}
                  {% if statut == 'en_attente' %}
                    <span style="background: var(--color-warning-light); color: var(--color-warning); padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: var(--text-small);">En attente</span>
                  {% elseif statut == 'confirmee' %}
                    <span style="background: var(--color-success-light); color: var(--color-success); padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: var(--text-small);">Confirmée</span>
                  {% elseif statut == 'livree' %}
                    <span style="background: #dbeafe; color: #1e40af; padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: var(--text-small);">Livrée</span>
                  {% elseif statut == 'annulee' %}
                    <span style="background: var(--color-danger-light); color: var(--color-danger); padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: var(--text-small);">Annulée</span>
                  {% else %}
                    <span style="background: var(--color-surface); color: var(--color-text-light); padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: var(--text-small);">{{ statut }}</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </div>

    {# Colonne droite : calendrier du mois en cours #}
    <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; box-shadow: var(--shadow-card);">
      {% set today = 'now'|date('Y-m-d') %}
      {% set year = 'now'|date('Y') %}
      {% set month = 'now'|date('m') %}
      {% set monthName = 'now'|date('F', timezone='Europe/Paris') %}
      {% set firstDay = (year ~ '-' ~ month ~ '-01')|date('N') %}
      {% set daysInMonth = ('last day of ' ~ year ~ '-' ~ month)|date('d') %}

      <h3 style="margin: 0 0 1rem; font-size: var(--text-small); font-weight: 600; color: var(--color-text); display: flex; justify-content: space-between; align-items: center;">
        <span><i class="fa fa-calendar" style="margin-right: 0.5rem; color: var(--color-text-light);"></i>{{ monthName }} {{ year }}</span>
        <span style="font-size: var(--text-small); color: var(--color-text-light); font-weight: 400;">
          <i class="fa fa-circle" style="color: var(--color-warning);"></i> = commandes
        </span>
      </h3>

      {# En-têtes jours #}
      <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; margin-bottom: 0.25rem;">
        {% for day in ['L','M','M','J','V','S','D'] %}
          <div style="text-align: center; font-size: var(--text-small); font-weight: 600; color: var(--color-text-light); padding: 0.25rem 0;">{{ day }}</div>
        {% endfor %}
      </div>

      {# Cases du calendrier #}
      <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;">
        {% for i in 1..(firstDay - 1) %}
          <div style="padding: 0.375rem; min-height: 2.5rem;"></div>
        {% endfor %}

        {% for d in 1..daysInMonth %}
          {% set dateKey = year ~ '-' ~ month ~ '-' ~ (d < 10 ? '0' ~ d : d) %}
          {% set hasCommande = commandesParDate[dateKey] is defined %}
          {% set isToday = dateKey == today %}

          <div style="
            text-align: center;
            padding: 0.375rem 0.25rem;
            min-height: 2.5rem;
            border-radius: var(--radius-sm);
            font-size: var(--text-small);
            position: relative;
            {{ isToday ? 'background: var(--color-warning); color: var(--color-bg); font-weight: 700;' : '' }}
            {{ hasCommande and not isToday ? 'background: var(--color-warning-light); color: var(--color-warning);' : '' }}
          ">
            {{ d }}
            {% if hasCommande %}
              <div style="
                position: absolute;
                bottom: 3px;
                left: 50%;
                transform: translateX(-50%);
                width: 5px; height: 5px;
                border-radius: 50%;
                background: {{ isToday ? 'var(--color-bg)' : 'var(--color-warning)' }};
              "></div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if commandesParDate is not empty %}
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border); font-size: var(--text-small); color: var(--color-text-light);">
          {{ commandesParDate|length }} jour(s) avec commande(s) ce mois-ci
        </div>
      {% endif %}
    </div>

  </div>
</div>
{% endblock %}
