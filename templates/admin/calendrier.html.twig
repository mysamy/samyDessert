{% extends '@EasyAdmin/page/content.html.twig' %}

{% block head_javascript %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/locales/fr.global.min.js"></script>
{% endblock %}

{% block content_title %}Calendrier des commandes{% endblock %}

{% block main %}
<div style="padding: 1.5rem;">

    {# Bannière "en cours de développement" #}
    <div style="display: flex; align-items: center; gap: 0.6rem; background: var(--color-warning-light); border: 1px solid var(--color-warning); border-radius: var(--radius-sm); padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: var(--text-small); color: var(--color-warning);">
        <span>🚧</span>
        <span>Fonctionnalité en cours de développement — non disponible pour le moment.</span>
    </div>

    {# Légende des couleurs de statut #}
    <div style="display: flex; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; opacity: 0.4; pointer-events: none;">
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-small); color: var(--color-text-light);">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: var(--color-warning);"></span> En attente
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-small); color: var(--color-text-light);">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: var(--color-success);"></span> Confirmée
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-small); color: var(--color-text-light);">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #3b82f6;"></span> Livrée
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: var(--text-small); color: var(--color-text-light);">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: var(--color-danger);"></span> Annulée
        </span>
    </div>

    {# Calendrier FullCalendar — grisé #}
    <div style="position: relative;">
        <div style="opacity: 0.3; pointer-events: none; filter: grayscale(1); background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 1.5rem; box-shadow: var(--shadow-card);">
            <div
                data-controller="fullcalendar"
                data-fullcalendar-events-url-value="{{ path('admin_calendrier_events') }}"
            ></div>
        </div>
    </div>

</div>
{% endblock %}
