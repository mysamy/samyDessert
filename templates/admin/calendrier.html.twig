{% extends '@EasyAdmin/page/content.html.twig' %}

{% block head_javascript %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.20/locales/fr.global.min.js"></script>
{% endblock %}

{% block content_title %}Calendrier des commandes{% endblock %}

{% block main %}
<div style="padding: 1.5rem;">

    {# Bannière "en cours de développement" #}
    <div style="display: flex; align-items: center; gap: 0.6rem; background: #fef9c3; border: 1px solid #fde047; border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.5rem; font-size: 0.875rem; color: #713f12;">
        <span style="font-size: 1.1rem;">🚧</span>
        <span>Fonctionnalité en cours de développement — non disponible pour le moment.</span>
    </div>

    {# Légende des couleurs de statut #}
    <div style="display: flex; gap: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; opacity: 0.4; pointer-events: none;">
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #374151;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #f59e0b;"></span> En attente
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #374151;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #22c55e;"></span> Confirmée
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #374151;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #3b82f6;"></span> Livrée
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #374151;">
            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background: #ef4444;"></span> Annulée
        </span>
    </div>

    {# Calendrier FullCalendar — grisé #}
    <div style="position: relative;">
        <div style="opacity: 0.3; pointer-events: none; filter: grayscale(1); background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 1px 3px rgba(0,0,0,.06);">
            <div
                data-controller="fullcalendar"
                data-fullcalendar-events-url-value="{{ path('admin_calendrier_events') }}"
            ></div>
        </div>
    </div>

</div>
{% endblock %}
