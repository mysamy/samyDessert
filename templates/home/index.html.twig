{% extends 'base.html.twig' %}

{% block title %}SamyDessert — Pâtisserie artisanale{% endblock %}

{% block body %}

{# carousel #}
<section class="py-16">
  <div class="container-main flex flex-col gap-8">

    <div class="text-center">
      <h1 class="text-title font-bold text-text mb-4">SamyDessert</h1>
      <p class="text-body text-text-light mb-8">Des desserts artisanaux préparés avec passion</p>
      <twig:Atoms:Link href="{{ path('app_produits') }}" variant="cta">
        Voir nos desserts
        <twig:Atoms:Icon name="arrow-right" :decorative="true"/>
      </twig:Atoms:Link>
    </div>

    <div data-controller="carousel" class="w-full flex min-h-[650px] justify-center relative overflow-hidden items-center" role="region" aria-roledescription="carrousel" aria-label="Nos spécialités">

      {% for produit in carouselProduits %}
        <twig:Molecules:CarouselCard
          class="flex-col gap-2.5 justify-center"
          imgSrc="{{ produit.imageName ? vich_uploader_asset(produit, 'imageFile') : '' }}"
          imgAlt="{{ produit.nom }}"
          description="{{ produit.description }}"
          url="{{ path('app_produit_show', { slug: produit.slug }) }}"
        />
      {% endfor %}

    </div>

  </div>
</section>

{# ── Produits phares ── #}
<section class="py-16">
  <div class="container-main">
    <h2 class="section-title mb-10">Nos meilleures ventes</h2>
    <twig:Organisms:ProductCardGrid :items="meilleursVendus" :favorisIds="produitsFavorisIds" :ratingsMap="ratingsMap" />
    <div class="text-center mt-10">
      <twig:Atoms:Link href="{{ path('app_produits') }}" variant="outline">
        Voir tous les desserts
        <twig:Atoms:Icon name="arrow-right" :decorative="true"/>
      </twig:Atoms:Link>
    </div>
  </div>
</section>

{# ── Nos valeurs ── #}
<section class="py-16 bg-surface">
  <div class="container-main">
    <h2 class="section-title mb-12">Nos valeurs</h2>
    <div class="grid gap-8 sm:grid-cols-3 text-center">

      <div class="flex flex-col items-center gap-4">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-primary-light text-primary text-subtitle">
          <twig:Atoms:Icon name="leaf" :decorative="true"/>
        </div>
        <h3 class="text-body font-semibold text-text">Ingrédients frais</h3>
        <p class="text-text-light text-small leading-relaxed">Nous sélectionnons des produits locaux et de saison pour des saveurs authentiques.</p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-primary-light text-primary text-subtitle">
          <twig:Atoms:Icon name="hands" :decorative="true"/>
        </div>
        <h3 class="text-body font-semibold text-text">Fait à la main</h3>
        <p class="text-text-light text-small leading-relaxed">Chaque dessert est façonné avec soin, sans compromis sur la qualité artisanale.</p>
      </div>

      <div class="flex flex-col items-center gap-4">
        <div class="flex items-center justify-center w-16 h-16 rounded-full bg-primary-light text-primary text-subtitle">
          <twig:Atoms:Icon name="gift" :decorative="true"/>
        </div>
        <h3 class="text-body font-semibold text-text">Sur commande</h3>
        <p class="text-text-light text-small leading-relaxed">Anniversaires, mariages, événements — nous créons le dessert qui correspond à votre moment.</p>
      </div>

    </div>
  </div>
</section>

{# ── Témoignages ── #}
<section class="py-16 bg-bg">
  <div class="container-main">
    <h2 class="section-title mb-12">Ce que nos clients disent</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

      <figure class="bg-surface rounded-lg p-6 flex flex-col gap-4">
        <twig:Atoms:StarRating :note="5" />
        <blockquote class="text-primary text-small leading-relaxed flex-1">
          "Les macarons sont absolument divins. Je commande pour tous mes événements, on ne peut plus s'en passer !"
        </blockquote>
        <figcaption class="text-accent text-small font-semibold">— Sophie M.</figcaption>
      </figure>

      <figure class="bg-surface rounded-lg p-6 flex flex-col gap-4">
        <twig:Atoms:StarRating :note="5" />
        <blockquote class="text-primary text-small leading-relaxed flex-1">
          "Gâteau de mariage sur commande, livré à temps et magnifique. Tous nos invités ont adoré. Merci Samy !"
        </blockquote>
        <figcaption class="text-accent text-small font-semibold">— Thomas & Léa</figcaption>
      </figure>

      <figure class="bg-surface rounded-lg p-6 flex flex-col gap-4">
        <twig:Atoms:StarRating :note="5" />
        <blockquote class="text-primary text-small leading-relaxed flex-1">
          "La tarte aux fraises est un régal. Produits frais, goût authentique, je recommande vivement !"
        </blockquote>
        <figcaption class="text-accent text-small font-semibold">— Camille R.</figcaption>
      </figure>

    </div>
  </div>
</section>

{# ── CTA commande personnalisée ── #}
<section class="py-20 bg-accent">
  <div class="container-main text-center">
    <h2 class="text-section font-bold text-white mb-4">Un événement à célébrer ?</h2>
    <p class="text-surface text-body mb-8 max-w-xl mx-auto">Contactez-nous pour créer le gâteau de vos rêves. Devis gratuit, livraison possible.</p>
    <twig:Atoms:Link href="{{ path('app_contact') }}" variant="white">
      Nous contacter
      <twig:Atoms:Icon name="envelope" :decorative="true"/>
    </twig:Atoms:Link>
  </div>
</section>

{% endblock %}
